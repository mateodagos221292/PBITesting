Status_Basic = SWITCH(TRUE(),'AS_Operations_Dashboard'[IsEnded]="Y","Completed",'AS_Operations_Dashboard'[IsStarted]="Y","In Progress","Not started")

MoveTypeLab = SWITCH(TRUE(),AS_Operations_Dashboard[from_movement_type]="production"&&AS_Operations_Dashboard[to_movement_type]="shipment","Express from production",AS_Operations_Dashboard[from_movement_type]="receipt"&&AS_Operations_Dashboard[to_movement_type]="#unknown","Receipt to storage",AS_Operations_Dashboard[from_movement_type]="production"&&AS_Operations_Dashboard[to_movement_type]="#unknown","Production to storage",AS_Operations_Dashboard[from_movement_type]="#unknown"&&AS_Operations_Dashboard[to_movement_type]="shipment","Shipment from storage",AS_Operations_Dashboard[from_movement_type]="#unknown"&&AS_Operations_Dashboard[to_movement_type]="consumption","Consumption from storage",AS_Operations_Dashboard[from_movement_type]="receipt"&&AS_Operations_Dashboard[to_movement_type]="consumption","Receipt to consumption",AS_Operations_Dashboard[from_movement_type]="receipt"&&AS_Operations_Dashboard[to_movement_type]="shipment","Crossdock","Check")

MoveTypeUnified = VAR lbl='AS_Operations_Dashboard'[MoveTypeLab] VAR hasShp=NOT ISBLANK('AS_Operations_Dashboard'[shipment_id]) VAR hasRcp=NOT ISBLANK('AS_Operations_Dashboard'[receipt_id]) RETURN SWITCH(TRUE(),lbl="Crossdock","Crossdock",hasShp&&NOT hasRcp,"Outbound",hasRcp&&NOT hasShp,"Inbound",hasShp&&hasRcp,"Outbound & Inbound",BLANK())

Ended_Any = COALESCE('AS_Operations_Dashboard'[ended_shipment],'AS_Operations_Dashboard'[ended_receipt])

AssignedDoor = VAR lbl=UPPER(TRIM('AS_Operations_Dashboard'[MoveTypeLab]&"")) VAR r0='AS_Operations_Dashboard'[door_id_assigned_receipt] VAR s0='AS_Operations_Dashboard'[door_id_assigned_shipment] VAR r=IF(LEN(TRIM(r0&""))=0,BLANK(),r0) VAR s=IF(LEN(TRIM(s0&""))=0,BLANK(),s0) RETURN IF(lbl="CROSSDOCK",IF(NOT ISBLANK(r)&&NOT ISBLANK(s),r&" -> "&s,COALESCE(r,s)),COALESCE(r,s))

OriginCustomer_Unified = VAR lbl='AS_Operations_Dashboard'[MoveTypeLab] VAR orig='AS_Operations_Dashboard'[origin] VAR cust=SUBSTITUTE(SUBSTITUTE(SUBSTITUTE('AS_Operations_Dashboard'[customers],"[",""),"]",""),"""","") RETURN IF(lbl="Crossdock",IF(NOT ISBLANK(orig)&&NOT ISBLANK(cust),orig&" → "&cust,COALESCE(orig,cust)),COALESCE(orig,cust))

LateFlag = VAR ReceiptLatePast=NOT ISBLANK(AS_Operations_Dashboard[ended_utc_receipt])&&NOT ISBLANK(AS_Operations_Dashboard[late_after_utc_receipt])&&AS_Operations_Dashboard[ended_utc_receipt]>=AS_Operations_Dashboard[late_after_utc_receipt] VAR ShipmentLatePast=NOT ISBLANK(AS_Operations_Dashboard[ended_utc_shipment])&&NOT ISBLANK(AS_Operations_Dashboard[late_after_utc_shipment])&&AS_Operations_Dashboard[ended_utc_shipment]>=AS_Operations_Dashboard[late_after_utc_shipment] VAR ReceiptExpectLate=NOT ISBLANK(AS_Operations_Dashboard[MaxEnd_UTC])&&NOT ISBLANK(AS_Operations_Dashboard[late_after_utc_receipt])&&NOT ISBLANK(AS_Operations_Dashboard[receipt_id])&&AS_Operations_Dashboard[MaxEnd_UTC]>=AS_Operations_Dashboard[late_after_utc_receipt] VAR ShipmentExpectLate=NOT ISBLANK(AS_Operations_Dashboard[MaxEnd_UTC])&&NOT ISBLANK(AS_Operations_Dashboard[late_after_utc_shipment])&&NOT ISBLANK(AS_Operations_Dashboard[shipment_id])&&AS_Operations_Dashboard[MaxEnd_UTC]>=AS_Operations_Dashboard[late_after_utc_shipment] RETURN SWITCH(TRUE(),ReceiptLatePast||ShipmentLatePast,"Late",ReceiptExpectLate||ShipmentExpectLate,"Not Late","Not Late")

Cases_Left = 'AS_Operations_Dashboard'[Cases_Expected_Ordered]-'AS_Operations_Dashboard'[Cases_Received_Loaded]