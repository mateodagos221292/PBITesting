expression get_token = ```
		let
		    GetToken = () =>
		    let
		        scope = "openid",
		        AUTH_URL = auth_host & "/auth/realms/GeneralMills/protocol/openid-connect/token",
		        AUTH_OPTIONS = [
		            Headers = [#"Content-Type" = "application/x-www-form-urlencoded"],
		            Content = Text.ToBinary(
		                "grant_type=client_credentials" &
		                "&client_id=" & client_id &
		                "&client_secret=" & client_secret &
		                "&scope=" & scope
		            )
		        ],
		        AUTH_RES = Json.Document(Web.Contents(AUTH_URL, AUTH_OPTIONS)),
		        ACCESS_TOKEN = AUTH_RES[access_token]
		    in
		        ACCESS_TOKEN
		in
		    GetToken
		    /*let
		    GetToken = () =>
		    let
		        scope = "openid",
		        AUTH_URL = auth_host & "/auth/realms/pepsico/protocol/openid-connect/token",
		        
		        AUTH_OPTIONS = [
		            Headers = [#"Content-Type" = "application/x-www-form-urlencoded"],
		            Content = Text.ToBinary(
		                "grant_type=client_credentials" &
		                "&client_id=" & client_id &
		                "&client_secret=" & client_secret &
		                "&scope=" & scope
		            )
		        ],
		        AUTH_RES = Json.Document(Web.Contents(AUTH_URL, AUTH_OPTIONS)),
		        ACCESS_TOKEN = AUTH_RES[access_token]
		    in
		        ACCESS_TOKEN
		in
		    GetToken
		    */
		```
	lineageTag: d114ed5e-1af5-4aa5-ae79-0ba630db1d3a

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression call_api = ```
		let
		    CallAPI = (api_path as text, optional table_type as type) =>
		    let
		        // Report Parameters
		        ACCESS_TOKNE = get_token(),
		        API_ENDPOINT = "/" & environment & api_path & "?siteId=" & site_id,
		        
		        // Call to API
		        API_OPTIONS = [
		            Headers = [
		                Authorization = "Bearer " & ACCESS_TOKNE,
		                #"Content-Type" = "application/json; charset=utf-8"
		            ],
		            RelativePath = API_ENDPOINT,
		            Timeout = #duration(0,0,5,0)
		        ],
		        API_RESPONSE = Web.Contents("https://api.autoscheduler.ai", API_OPTIONS),
		        JSON_DATA = Json.Document(API_RESPONSE),
		        
		        RESULT_TABLE = if table_type = null then
		            Table.FromRecords(JSON_DATA)
		        else
		            let
		                base_table = Table.FromRecords(JSON_DATA, table_type),
		                
		                table_schema = Type.RecordFields(Type.TableRow(table_type)),
		                
		                datetime_columns = List.Select(
		                    Record.FieldNames(table_schema),
		                    each Record.Field(table_schema, _)[Type] = type datetime
		                ),
		                
		                logical_columns = List.Select(
		                    Record.FieldNames(table_schema),
		                    each Record.Field(table_schema, _)[Type] = type logical
		                ),
		                
		                datetime_conversions = List.Transform(
		                    datetime_columns,
		                    each {_, (val) => 
		                        if val = null or val = "" then null 
		                        else if val is text then DateTime.FromText(val, "en-US") 
		                        else val, 
		                        type datetime}
		                ),
		                
		                logical_conversions = List.Transform(
		                    logical_columns,
		                    each {_, (val) => 
		                        if val = null then null
		                        else if val is logical then val
		                        else if val is number then (val = 1)
		                        else if val is text then (val = "TRUE" or val = "true" or val = "1")
		                        else null,
		                        type logical}
		                ),
		                
		                all_conversions = datetime_conversions & logical_conversions,
		                
		                converted_table = Table.TransformColumns(base_table, all_conversions)
		            in
		                converted_table
		    in
		        RESULT_TABLE
		in
		    CallAPI
		```
	lineageTag: 8f4ff3a7-5d05-499b-8968-c4dfb6b8506c

