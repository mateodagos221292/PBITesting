	partition AS_Shipments = m
		mode: import
		source =
				let
				    convert_to_table = call_api(
				        "/external-view/shipment",
				        type table [
				            site_id = text,
				            shipment_id = text,
				            shipment_type_id = text,
				            is_live = logical,
				            appointment_date_UTC = datetime,
				            appointment_date = datetime,
				            transportation_type_id = text,
				            carrier_id = text,
				            trailer_id = text,
				            arrived_UTC = datetime,
				            arrived = datetime,
				            is_completed = logical,
				            assigned_door_id = text,
				            planned_arrival_utc = datetime,
				            planned_arrival = datetime,
				            note = text,
				            trailer_type = text
				        ]
				    )
				in
				    convert_to_table

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

