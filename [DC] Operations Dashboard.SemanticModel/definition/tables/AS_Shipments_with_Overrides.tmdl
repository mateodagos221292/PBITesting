	partition AS_Shipments_with_Overrides = m
		mode: import
		source =
				let
				    convert_to_table = call_api(
				        "/external-view/shipment-with-override",
				        type table [
				            site_id = text,
				            shipment_id = text,
				            shipment_type_id = text,
				            transportation_type_id = text,
				            carrier_id = text,
				            trailer_id = text,
				            trailer_type = text,
				            assigned_door_id = text,
				            is_live = logical,
				            is_completed = logical,
				            ignore = logical,
				            note = text,
				            planned_arrival_utc = datetime,
				            planned_arrival = datetime,
				            arrived_UTC = datetime,
				            arrived = datetime,
				            appointment_date_UTC = datetime,
				            appointment_date = datetime
				        ]
				    )
				in
				    convert_to_table

	annotation PBI_NavigationStepName = Navigation

