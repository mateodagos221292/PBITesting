	partition AS_Receipts_Log = m
		mode: import
		source =
				let
				    convert_to_table = call_api(
				        "/external-view/receipt-log",
				        type table [
				            site_id = text,
				            receipt_id = text,
				            receipt_type_id = text,
				            origin = text,
				            note = text,
				            is_live = logical,
				            planned_arrival_utc = datetime,
				            planned_arrival = datetime,
				            arrived_utc = datetime,
				            arrived = datetime,
				            appointment_date_utc = datetime,
				            appointment_date = datetime,
				            transportation_type_id = text,
				            started_utc = datetime,
				            started = datetime,
				            ended_utc = datetime,
				            ended = datetime,
				            carrier_id = text,
				            trailer_id = text,
				            door_id = text,
				            door_assigned_utc = datetime,
				            door_assigned = datetime,
				            last_updated_utc = datetime,
				            last_updated = datetime,
				            first_updated_utc = datetime,
				            first_updated = datetime,
				            late_after_utc = datetime,
				            late_after = datetime,
				            last_scheduled_end_utc = datetime,
				            last_scheduled_end = datetime,
				            expected_items = number,
				            expected_buom = number,
				            expected_cases = number,
				            expected_ULs = number,
				            expected_kg = number,
				            expected_weight = number,
				            expected_cm3 = number,
				            expected_volume = number,
				            received_items = number,
				            received_buom = number,
				            received_cases = number,
				            received_ULs = number,
				            received_kg = number,
				            received_weight = number,
				            received_cm3 = number,
				            received_volume = number
				        ]
				    )
				in
				    convert_to_table

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

