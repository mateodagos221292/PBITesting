	partition AS_Shipments_Overrides = m
		mode: import
		source =
				let
				    convert_to_table = call_api(
				        "/external-view/shipment-override",
				        type table [
				            site_id = text,
				            shipment_id = text,
				            shipment_type_id = text,
				            transportation_type_id = text,
				            trailer_type = text,
				            is_live = logical,
				            ignore = logical,
				            manual_override = logical,
				            note = text,
				            planned_arrival_utc = datetime,
				            planned_arrival = datetime,
				            arrived_UTC = datetime,
				            arrived = datetime,
				            appointment_date_UTC = datetime,
				            appointment_date = datetime,
				            last_updated = datetime,
				            last_updated_utc = datetime,
				            last_updated_by = text
				        ]
				    )
				in
				    convert_to_table

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

