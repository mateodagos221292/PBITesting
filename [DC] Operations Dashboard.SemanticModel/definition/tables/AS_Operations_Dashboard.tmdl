	column CarrierID = ```
			
			VAR rcpt = 'AS_Operations_Dashboard'[carrier_id_receipt]
			VAR ship = 'AS_Operations_Dashboard'[carrier_id_shipment]
			RETURN
			    COALESCE(ship, rcpt)
			
			```
		lineageTag: 891158db-27ec-4e13-a6c0-82ae0ddc2534
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition AS_Operations_Dashboard = m
		mode: import
		source = ```
				let
				    // ============================================
				    // 1. LOAD & NORMALIZE KEYS - BUFFER FOR PRIVACY
				    // ============================================
				    
				    // Buffer sources to help with privacy settings
				    Source_Schedule = Table.Buffer(AS_Result_Schedule_Activity_Data),
				    Source_Shipments = Table.Buffer(AS_Shipments_Log),
				    Source_Receipts = Table.Buffer(AS_Receipts_Log),
				    Source_Doors = Table.Buffer(AS_Result_Door_Assignment),
				    Source_Overrides = Table.Buffer(AS_Shipments_with_Overrides),
				    Source_Door_Compliance = Table.Buffer(AS_RES_Door_Assignment_Compliance),
				    
				    Schedule_Raw = Source_Schedule,
				
				    // ============================================
				    // 2. NORMALIZE AND AGGREGATE SCHEDULE TO MOVEMENT LEVEL
				    // ============================================
				    
				    // Step 1: Add normalized columns for production AND preserve originals for crossdock detection
				    Schedule_WithNormalizedID = 
				        Table.AddColumn(
				            Table.AddColumn(
				                Table.AddColumn(
				                    Schedule_Raw,
				                    "from_movement_type_original",  // Preserve original for crossdock detection
				                    each [from_movement_type],
				                    type text
				                ),
				                "from_movement_id_norm",
				                each 
				                    if [from_movement_type] = "production" then "#UNKNOWN"
				                    else [from_movement_id],
				                type text
				            ),
				            "from_movement_type_norm",
				            each 
				                if [from_movement_type] = "production" then "#unknown"
				                else [from_movement_type],
				            type text
				        ),
				
				    // Step 2: Transform and normalize keys, filter move trailer
				    Schedule_Normalized = 
				        Table.SelectRows(
				            Table.TransformColumns(
				                Schedule_WithNormalizedID,
				                {
				                    {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                    {"to_movement_id", each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text},
				                    {"from_movement_id_norm", each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text},
				                    {"from_movement_type_norm", each if _ = null then null else Text.Lower(Text.Trim(Text.From(_))), type text},
				                    {"from_movement_type_original", each if _ = null then null else Text.Lower(Text.Trim(Text.From(_))), type text}
				                }
				            ),
				            each [action_id] <> "move trailer"
				        ),
				
				    // Step 3: Replace from_movement_id and from_movement_type with normalized versions (keep original for detection)
				    Schedule_Final = 
				        Table.RenameColumns(
				            Table.RemoveColumns(
				                Schedule_Normalized, 
				                {"from_movement_id", "from_movement_type"}
				            ),
				            {
				                {"from_movement_id_norm", "from_movement_id"},
				                {"from_movement_type_norm", "from_movement_type"}
				            }
				        ),
				    
				    // Step 4: Aggregate to movement level with production AND crossdock flags
				    ScheduleMovements = 
				        Table.Group(
				            Schedule_Final,
				            {"site_id", "to_movement_id", "from_movement_id", "to_movement_type", "from_movement_type"},
				            {
				                {"MinStart", each List.Min([start]), type nullable datetime},
				                {"MaxEnd", each List.Max([end]), type nullable datetime},
				                {"MinStart_UTC", each List.Min([start_utc]), type nullable datetime},
				                {"MaxEnd_UTC", each List.Max([end_utc]), type nullable datetime},
				                {"ActivityCount", each Table.RowCount(_), Int64.Type},
				                {"HasProductionSource", each List.Contains([action_id], "UL pick from production"), type logical},
				                {"HasCrossdockActivity", each 
				                    Table.RowCount(
				                        Table.SelectRows(
				                            _,
				                            each [from_movement_type_original] = "receipt" and [to_movement_type] = "shipment"
				                        )
				                    ) > 0,
				                    type logical
				                },
				                {"HasConsumption", each List.Contains([action_id], "ul trailer to consumption"), type logical}  
				            }
				        ),
				    
				    // Normalize other sources
				    Shipments_Normalized = 
				        Table.SelectRows(
				            Table.TransformColumns(
				                Source_Shipments,
				                {
				                    {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                    {"shipment_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				                }
				            ),
				            each [shipment_type_id] <> "freightUnit"
				        ),
				    
				    Receipts_Normalized = 
				        Table.TransformColumns(
				            Source_Receipts,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"receipt_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				    
				    Doors_Normalized = 
				        Table.TransformColumns(
				            Source_Doors,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				    DoorCompliance_Normalized = 
				        Table.TransformColumns(
				            Source_Door_Compliance,
				            {
				                {"movement_id", each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"proposed_door_id", each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				    DoorCompliance_Distinct = 
				    Table.Distinct(
				        Table.SelectColumns(
				            DoorCompliance_Normalized,
				            {"movement_id", "proposed_door_id", "used_door_id"}  
				        ),
				        {"movement_id"}
				    ),
				
				    // ============================================
				    // 3. ADD "NO SCHEDULE" MOVEMENTS FROM LOGS
				    // ============================================
				    
				    // Shipments that started but not in schedule
				    ShipmentsStarted = 
				        Table.SelectRows(Shipments_Normalized, each [started_utc] <> null),
				    
				    ShipmentsNotInSchedule = 
				        Table.NestedJoin(
				            ShipmentsStarted,
				            {"site_id", "shipment_id"},
				            Table.SelectColumns(ScheduleMovements, {"site_id", "to_movement_id"}),
				            {"site_id", "to_movement_id"},
				            "InSched",
				            JoinKind.LeftAnti
				        ),
				    
				    ShipmentsNotInSchedule_Keyed = 
				        Table.AddColumn(
				            Table.AddColumn(
				                Table.AddColumn(
				                    ShipmentsNotInSchedule,
				                    "to_movement_id", each [shipment_id], type text
				                ),
				                "from_movement_id", each null, type text
				            ),
				            "to_movement_type", each "shipment", type text
				        ),
				    
				    // Receipts that started but not in schedule
				    ReceiptsStarted = 
				        Table.SelectRows(Receipts_Normalized, each [started_utc] <> null),
				    
				    ReceiptsNotInSchedule = 
				        Table.NestedJoin(
				            ReceiptsStarted,
				            {"site_id", "receipt_id"},
				            Table.SelectColumns(ScheduleMovements, {"site_id", "from_movement_id"}),
				            {"site_id", "from_movement_id"},
				            "InSched",
				            JoinKind.LeftAnti
				        ),
				    
				    ReceiptsNotInSchedule_Keyed = 
				        Table.AddColumn(
				            Table.AddColumn(
				                Table.AddColumn(
				                    ReceiptsNotInSchedule,
				                    "from_movement_id", each [receipt_id], type text
				                ),
				                "to_movement_id", each null, type text
				            ),
				            "from_movement_type", each "receipt", type text
				        ),
				    
				    // Combine ALL movements into single table
				    AllMovements = 
				        Table.Combine({
				            ScheduleMovements,
				            Table.SelectColumns(
				                ShipmentsNotInSchedule_Keyed, 
				                {"site_id", "to_movement_id", "from_movement_id", "to_movement_type"}
				            ),
				            Table.SelectColumns(
				                ReceiptsNotInSchedule_Keyed, 
				                {"site_id", "to_movement_id", "from_movement_id", "from_movement_type"}
				            )
				        }),
				
				    // ============================================
				    // 4. ADD MOVEMENT TYPE FLAGS
				    // ============================================
				    
				    WithFlags = 
				        Table.AddColumn(
				            Table.AddColumn(
				                Table.AddColumn(
				                    Table.AddColumn(
				                        AllMovements,
				                        "IsCrossdock",
				                        each [HasCrossdockActivity] = true,
				                        type logical
				                    ),
				                    "IsShipmentOnly",
				                    each 
				                        [to_movement_id] <> null and [to_movement_id] <> "#UNKNOWN" and
				                        ([from_movement_id] = null or [from_movement_id] = "#UNKNOWN"),
				                    type logical
				                ),
				                "IsReceiptOnly",
				                each 
				                    [from_movement_id] <> null and [from_movement_id] <> "#UNKNOWN" and
				                    ([to_movement_id] = null or [to_movement_id] = "#UNKNOWN"),
				                type logical
				            ),
				            "MovementType",
				            each 
				                if [HasConsumption] = true then "Inbound"  // Consumption is inbound 
				                else if [IsCrossdock] then "Crossdock" // Crossdock is both
				                else if [IsShipmentOnly] then "Outbound"
				                else if [IsReceiptOnly] then "Inbound"
				                else "Unknown",
				            type text
				        ),
				
				    // ============================================
				    // 5. MERGE SHIPMENT DATA
				    // ============================================
				    
				    WithShipments = 
				        Table.NestedJoin(
				            WithFlags,
				            {"site_id", "to_movement_id"},
				            Shipments_Normalized,
				            {"site_id", "shipment_id"},
				            "Shipment",
				            JoinKind.LeftOuter
				        ),
				    
				    ExpandShipments = 
				        Table.ExpandTableColumn(
				            WithShipments,
				            "Shipment",
				            {"shipment_id", "shipment_type_id", "customers", "note", "is_live", 
				             "appointment_date", "appointment_date_utc", 
				             "started", "started_utc", "ended", "ended_utc",
				             "late_after", "late_after_utc",
				             "carrier_id", "trailer_id", "transportation_type_id",
				             "door_id",
				             "ordered_cases", "loaded_cases"},
				            {"shipment_id", "shipment_type_id", "customers", "note_shipment", "is_live_shipment",
				             "appointment_date_shipment", "appointment_date_utc_shipment",
				             "started_shipment", "started_utc_shipment", "ended_shipment", "ended_utc_shipment",
				             "late_after_shipment", "late_after_utc_shipment",
				             "carrier_id_shipment", "trailer_id_shipment", "transportation_type_shipment",
				             "door_id_actual_shipment",
				             "ordered_cases", "loaded_cases"}
				        ),
				    
				    // ============================================
				    // 6. FILTER OUT FREIGHTUNIT AFTER MERGE
				    // ============================================
				    
				    FilteredShipments = 
				        Table.SelectRows(
				            ExpandShipments,
				            each [shipment_type_id] <> "freightUnit" or [shipment_type_id] = null
				        ),
				    
				    // ============================================
				    // 7. MERGE RECEIPT DATA
				    // ============================================
				    
				    WithReceipts = 
				        Table.NestedJoin(
				            FilteredShipments,
				            {"site_id", "from_movement_id"},
				            Receipts_Normalized,
				            {"site_id", "receipt_id"},
				            "Receipt",
				            JoinKind.LeftOuter
				        ),
				    
				    ExpandReceipts = 
				        Table.ExpandTableColumn(
				            WithReceipts,
				            "Receipt",
				            {"receipt_id", "receipt_type_id", "origin", "note", "is_live",
				             "appointment_date", "appointment_date_utc",
				             "started", "started_utc", "ended", "ended_utc",
				             "late_after", "late_after_utc",
				             "carrier_id", "trailer_id", "transportation_type_id",
				              "door_id",
				             "expected_cases", "received_cases"},
				            {"receipt_id", "receipt_type_id", "origin", "note_receipt", "is_live_receipt",
				             "appointment_date_receipt", "appointment_date_utc_receipt",
				             "started_receipt", "started_utc_receipt", "ended_receipt", "ended_utc_receipt",
				             "late_after_receipt", "late_after_utc_receipt",
				             "carrier_id_receipt", "trailer_id_receipt", "transportation_type_receipt",
				             "door_id_actual_receipt",
				             "expected_cases", "received_cases"}
				        ),
				    
				    // ============================================
				    // 8. MERGE DOOR ASSIGNMENTS
				    // ============================================
				    
				    // Door for shipments (to_movement_id)
				    WithDoors_Ship = 
				        Table.NestedJoin(
				            ExpandReceipts,
				            {"site_id", "to_movement_id"},
				            Doors_Normalized,
				            {"site_id", "movement_id"},
				            "Door_Ship",
				            JoinKind.LeftOuter
				        ),
				    ExpandDoors_Ship = 
				        Table.ExpandTableColumn(
				            WithDoors_Ship, "Door_Ship", {"door_id"}, {"door_id_proposed_shipment"}
				        ),
				    
				    // Door for receipts (from_movement_id)
				    WithDoors_Rcpt = 
				        Table.NestedJoin(
				            ExpandDoors_Ship,
				            {"site_id", "from_movement_id"},
				            Doors_Normalized,
				            {"site_id", "movement_id"},
				            "Door_Rcpt",
				            JoinKind.LeftOuter
				        ),
				    ExpandDoors_Rcpt = 
				        Table.ExpandTableColumn(
				            WithDoors_Rcpt, "Door_Rcpt", {"door_id"}, {"door_id_proposed_receipt"}
				        ),
				
				
				    // ============================================
				    // 9. MERGE TRAILER TYPES
				    // ============================================
				    
				    WithTrailerTypes = 
				        Table.NestedJoin(
				            ExpandDoors_Rcpt,
				            {"site_id", "shipment_id"},
				            Source_Overrides,
				            {"site_id", "shipment_id"},
				            "TrailerInfo",
				            JoinKind.LeftOuter
				        ),
				    ExpandTrailerTypes = 
				        Table.ExpandTableColumn(
				            WithTrailerTypes, "TrailerInfo", {"trailer_type"}, {"TrailerType_Shipment"}
				        ),
				
				    // ============================================
				    // JOIN DOOR COMPLIANCE - RECEIPTS
				    // ============================================
				
				    WithDoorCompliance_Receipts = 
				        Table.NestedJoin(
				            ExpandTrailerTypes,  
				            {"from_movement_id"},
				            DoorCompliance_Distinct,
				            {"movement_id"},
				            "DoorCompliance_Receipt",
				            JoinKind.LeftOuter
				        ),
				
				    ExpandDoorCompliance_Receipts = 
				        Table.ExpandTableColumn(
				            WithDoorCompliance_Receipts,
				            "DoorCompliance_Receipt",
				            {"proposed_door_id", "used_door_id"},
				            {"proposed_door_id_receipt", "used_door_id_receipt"}
				        ),
				
				    // ============================================
				    // JOIN DOOR COMPLIANCE - SHIPMENTS
				    // ============================================
				
				    WithDoorCompliance_Shipments = 
				        Table.NestedJoin(
				            ExpandDoorCompliance_Receipts,  
				            {"to_movement_id"},
				            DoorCompliance_Distinct,
				            {"movement_id"},
				            "DoorCompliance_Shipment",
				            JoinKind.LeftOuter
				        ),
				
				    ExpandDoorCompliance_Shipments = 
				        Table.ExpandTableColumn(
				            WithDoorCompliance_Shipments,
				            "DoorCompliance_Shipment",
				            {"proposed_door_id", "used_door_id"},
				            {"proposed_door_id_shipment", "used_door_id_shipment"}
				        ),
				
				    // ============================================
				    // CREATE UNIFIED PROPOSED DOOR COLUMN
				    // ============================================
				
				    Final_WithProposedDoor = 
				        Table.AddColumn(
				            ExpandDoorCompliance_Shipments,
				            "ProposedDoor_Unified",
				            each 
				                let
				                    // Priority: Current/Future sources first, then fallback to historical
				                    ProposedRcpt = if [door_id_proposed_receipt] <> null 
				                                   then [door_id_proposed_receipt] 
				                                   else [proposed_door_id_receipt],
				                    ProposedShip = if [door_id_proposed_shipment] <> null 
				                                   then [door_id_proposed_shipment] 
				                                   else [proposed_door_id_shipment]
				                in
				                    if [IsCrossdock] then
				                        if ProposedRcpt <> null and ProposedShip <> null then
				                            ProposedRcpt & " → " & ProposedShip
				                        else
				                            if ProposedShip <> null then ProposedShip else ProposedRcpt
				                    else
				                        if ProposedShip <> null then ProposedShip else ProposedRcpt,
				            type nullable text
				        ),
				
				    Final_WithAssignedDoor = 
				        Table.AddColumn(
				            Final_WithProposedDoor,
				            "AssignedDoor_Unified",
				            each 
				                let
				                    IsCompleted = [ended_utc_shipment] <> null or [ended_utc_receipt] <> null,
				                    
				                    // For completed: ONLY use compliance (logs have known errors)
				                    // For in-progress: use actual from logs
				                    AssignedRcpt = if IsCompleted 
				                                   then [used_door_id_receipt]
				                                   else [door_id_actual_receipt],
				                    AssignedShip = if IsCompleted 
				                                   then [used_door_id_shipment]
				                                   else [door_id_actual_shipment]
				                in
				                    if [IsCrossdock] then
				                        if AssignedRcpt <> null and AssignedShip <> null then
				                            AssignedRcpt & " → " & AssignedShip
				                        else
				                            if AssignedShip <> null then AssignedShip else AssignedRcpt
				                    else
				                        if AssignedShip <> null then AssignedShip else AssignedRcpt,
				            type nullable text
				            ),
				            
				    // ============================================
				    // 10. ADD CALCULATED COLUMNS
				    // ============================================
				    
				    WithCalculations = 
				        Table.AddColumn(
				            Table.AddColumn(
				                Table.AddColumn(
				                    Table.AddColumn(
				                        Table.AddColumn(
				                            Table.AddColumn(
				                                Final_WithAssignedDoor,
				                                "IsStarted",
				                                each if [started_utc_shipment] <> null or [started_utc_receipt] <> null 
				                                     then "Y" else "N",
				                                type text
				                            ),
				                            "IsEnded",
				                            each if [ended_utc_shipment] <> null or [ended_utc_receipt] <> null 
				                                 then "Y" else "N",
				                            type text
				                        ),
				                        "Cases_Expected_Ordered",
				                        each 
				                            if [IsCrossdock] then [expected_cases] ?? 0
				                            else if [IsShipmentOnly] then [ordered_cases] ?? 0
				                            else if [IsReceiptOnly] then [expected_cases] ?? 0
				                            else 0,
				                        type number
				                    ),
				                    "Cases_Received_Loaded",
				                    each 
				                        if [IsCrossdock] then [loaded_cases] ?? 0
				                        else if [IsShipmentOnly] then [loaded_cases] ?? 0
				                        else if [IsReceiptOnly] then [received_cases] ?? 0
				                        else 0,
				                    type number
				                ),
				                "MovementKey",
				                each Text.From([site_id]) & "|" & 
				                     Text.From([to_movement_id] ?? "") & "|" & 
				                     Text.From([from_movement_id] ?? ""),
				                type text
				            ),
				            "MoveID",
				            each 
				                if [HasConsumption] = true then 
				                    [from_movement_id]  // Consumption: use receipt ID
				                else if [IsCrossdock] = true then
				                    [from_movement_id] & " → " & [to_movement_id]  // Crossdock: show flow -- May want to remove this.
				                else if [to_movement_id] <> null and [to_movement_id] <> "#UNKNOWN" then 
				                    [to_movement_id]  // Shipment only: use shipment ID
				                else 
				                    [from_movement_id],  // Receipt only: use receipt ID
				            type text
				        ),
				
				    // ============================================
				    // 11. TYPE ENFORCEMENT
				    // ============================================
				    
				    FinalTyped = 
				        Table.TransformColumnTypes(
				            WithCalculations,
				            {
				                {"site_id", type text},
				                {"to_movement_id", type text},
				                {"from_movement_id", type text},
				                {"to_movement_type", type text},
				                {"from_movement_type", type text},
				                {"MovementType", type text},
				                {"IsCrossdock", type logical},
				                {"IsShipmentOnly", type logical},
				                {"IsReceiptOnly", type logical},
				                {"shipment_id", type text},
				                {"receipt_id", type text},
				                {"shipment_type_id", type text},
				                {"appointment_date_shipment", type datetime},
				                {"appointment_date_utc_shipment", type datetime},
				                {"started_shipment", type datetime},
				                {"started_utc_shipment", type datetime},
				                {"ended_shipment", type datetime},
				                {"ended_utc_shipment", type datetime},
				                {"late_after_shipment", type datetime},
				                {"late_after_utc_shipment", type datetime},
				                {"appointment_date_receipt", type datetime},
				                {"appointment_date_utc_receipt", type datetime},
				                {"started_receipt", type datetime},
				                {"started_utc_receipt", type datetime},
				                {"ended_receipt", type datetime},
				                {"ended_utc_receipt", type datetime},
				                {"late_after_receipt", type datetime},
				                {"late_after_utc_receipt", type datetime},
				                {"MinStart", type datetime},
				                {"MaxEnd", type datetime},
				                {"MinStart_UTC", type datetime},
				                {"MaxEnd_UTC", type datetime},
				                {"ordered_cases", type number},
				                {"loaded_cases", type number},
				                {"expected_cases", type number},
				                {"received_cases", type number},
				                {"Cases_Expected_Ordered", type number},
				                {"Cases_Received_Loaded", type number},
				                {"ActivityCount", Int64.Type}
				            },
				            "en-US"
				        )
				in
				    FinalTyped
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

