	column TrailerID_Unified =
			
			VAR rcpt = 'AS_Operations_Dashboard'[trailer_id_receipt]
			VAR ship = 'AS_Operations_Dashboard'[trailer_id_shipment]
			RETURN
			IF(
			    'AS_Operations_Dashboard'[IsCrossdock],
			    IF(NOT ISBLANK(rcpt) && NOT ISBLANK(ship),
			        rcpt & " → " & ship,
			        COALESCE(ship, rcpt)
			    ),
			    COALESCE(ship, rcpt)
			)
		lineageTag: adf8fffb-a4fa-4b2e-9bf0-206d0f544030
		summarizeBy: none

