	column OriginCustomer_Unified =
			
			VAR orig = 'AS_Operations_Dashboard'[origin]
			VAR cust = SUBSTITUTE(SUBSTITUTE(SUBSTITUTE('AS_Operations_Dashboard'[customers], "[", ""), "]", ""), """", "")
			RETURN
			IF(
			    'AS_Operations_Dashboard'[IsCrossdock],
			    IF(NOT ISBLANK(orig) && NOT ISBLANK(cust), orig & " → " & cust, COALESCE(orig, cust)),
			    COALESCE(orig, cust)
			)
		lineageTag: 82e2e740-1d42-4cec-8707-3152edd211d0
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Day Of Week' = FORMAT ( AS_Operations_Dashboard[Appointment Date], "ddd" )
		lineageTag: d43ac17d-372f-4ed8-bbe0-6f91929658dd
		summarizeBy: none
		sortByColumn: DayOfWeekSort

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column 'Appointment Date' =
			
			VAR r0 = 'AS_Operations_Dashboard'[appointment_date_receipt]
			VAR s0 = 'AS_Operations_Dashboard'[appointment_date_shipment]
			VAR r  = IF( LEN(TRIM(r0 & "")) = 0, BLANK(), r0 )
			VAR s  = IF( LEN(TRIM(s0 & "")) = 0, BLANK(), s0 )
			RETURN COALESCE( r, s )
		formatString: General Date
		lineageTag: b1f43e52-2947-47d5-87c9-4fb671c32d1a
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 86e79322-fd5f-472d-a6e6-6c7b7df7b6e4
			defaultHierarchy: LocalDateTable_bb5c6818-b0f4-4dd2-b9ee-cfc9a028f0f5.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column DayOfWeekSort = WEEKDAY ( AS_Operations_Dashboard[Appointment Date], 1 )
