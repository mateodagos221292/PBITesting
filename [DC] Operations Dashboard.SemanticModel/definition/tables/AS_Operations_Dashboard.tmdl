	column Status_Basic =
			
			SWITCH(
			    TRUE(),
			    'AS_Operations_Dashboard'[IsEnded] = "Y", "Completed",
			    'AS_Operations_Dashboard'[IsStarted] = "Y", "In Progress",
			    "Not started"
			)
		lineageTag: b53dab3c-987d-4e97-a0e7-148c697130ae
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MoveTypeLabel = ```
			
			SWITCH(
			    TRUE(),
			    'AS_Operations_Dashboard'[HasProductionSource] = TRUE, "Express from production",
			    'AS_Operations_Dashboard'[IsCrossdock], "Crossdock",
			    'AS_Operations_Dashboard'[HasConsumption] = TRUE, "Receipt to consumption",  
			    'AS_Operations_Dashboard'[IsShipmentOnly], "Shipment from storage",
			    'AS_Operations_Dashboard'[IsReceiptOnly], "Receipt to storage",
			   // AS_Operations_Dashboard[from_movement_type] = "production" && AS_Operations_Dashboard[to_movement_type] = "shipment", "Express from production",
			    AS_Operations_Dashboard[from_movement_type] = "production" && AS_Operations_Dashboard[to_movement_type] = "#unknown", "Production to storage",
			    AS_Operations_Dashboard[from_movement_type] = "#unknown" && AS_Operations_Dashboard[to_movement_type] = "consumption", "Consumption from storage",
			   // AS_Operations_Dashboard[from_movement_type] = "receipt" && AS_Operations_Dashboard[to_movement_type] = "consumption", "Receipt to consumption",
			    "Check"
			)
			```
		lineageTag: fe32888c-615b-4582-b818-5a4d9e920ad5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Ended_Any =
			
			COALESCE(
			    'AS_Operations_Dashboard'[ended_shipment],
			    'AS_Operations_Dashboard'[ended_receipt]
			)
		formatString: General Date
		lineageTag: 0998e8e9-b58c-4e1f-b332-99f8269eea04
		summarizeBy: none

		variation Variation
			isDefault
			relationship: d9c65e6a-efad-401f-817f-b76cc970d264
			defaultHierarchy: LocalDateTable_e8fa5b96-bff3-43b1-86e6-a0f8f25dcd49.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column Cases_Left =
			
			'AS_Operations_Dashboard'[Cases_Expected_Ordered] - 'AS_Operations_Dashboard'[Cases_Received_Loaded]
		lineageTag: da95ae5e-358c-49d8-a247-f6c627b040bd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column LateFlag =
			
			VAR ActualEnd = COALESCE(
			    'AS_Operations_Dashboard'[ended_utc_shipment],
			    'AS_Operations_Dashboard'[ended_utc_receipt]
			)
			VAR ScheduledEnd = 'AS_Operations_Dashboard'[MaxEnd_UTC]
			VAR LateDeadline = COALESCE(
			    'AS_Operations_Dashboard'[late_after_utc_shipment],
			    'AS_Operations_Dashboard'[late_after_utc_receipt]
			)
			
			VAR IsEnded = NOT ISBLANK(ActualEnd)
			VAR EndTime = IF(IsEnded, ActualEnd, ScheduledEnd)
			
			RETURN
			IF(
			    ISBLANK(LateDeadline),
			    "No Deadline",
			    IF(
			        NOT ISBLANK(EndTime) && EndTime >= LateDeadline,
			        IF(IsEnded, "Late", "Expect Late"),
			        "Not Late"
			    )
			)
		lineageTag: 1a74f19a-ea5a-41b2-adc6-6066296aeb6a
