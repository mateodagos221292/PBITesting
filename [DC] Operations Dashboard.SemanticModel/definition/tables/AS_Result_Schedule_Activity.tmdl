		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column DayOfWeek = FORMAT ( AS_Result_Schedule_Activity[AppointmentDate], "ddd" )
		lineageTag: b50e2fe3-28de-41e3-95d3-fab94777a637
		summarizeBy: none
		sortByColumn: DayOfWeekNum

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column DayOfWeekNum = WEEKDAY ( AS_Result_Schedule_Activity[AppointmentDate], 1 )
		formatString: 0
		lineageTag: d0172931-f83c-4e82-92ef-7ca1f71d508d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column WeeksBack =
			
			VAR d = 'AS_Result_Schedule_Activity'[AppointmentDate]
			VAR wkStart_d =
			    d - WEEKDAY ( d, 2 ) + 1        -- Monday of that date's week
			VAR wkStart_today =
			    TODAY() - WEEKDAY ( TODAY(), 2 ) + 1   -- Monday of this week
			RETURN
			IF(
			    ISBLANK(d),
			    BLANK(),
			    INT ( DIVIDE ( wkStart_today - wkStart_d, 7.0 ) )
			)
		dataType: double
		formatString: 0
		lineageTag: f92be98c-7185-497e-9f7e-a1cfae23588f
		summarizeBy: sum

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column WeekOfLabel =
			
			VAR d = 'AS_Result_Schedule_Activity'[AppointmentDate]
			VAR wkStart = d - WEEKDAY(d,1) + 1
			RETURN IF( ISBLANK(d), BLANK(), "Week of " & FORMAT(wkStart, "MMM dd") )
		lineageTag: c4249568-0b93-4d0b-8544-b52caea1592f
		summarizeBy: none
		sortByColumn: YearWeek

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column YearWeek =
			
			YEAR ( 'AS_Result_Schedule_Activity'[AppointmentDate] ) * 100
			+ WEEKNUM ( 'AS_Result_Schedule_Activity'[AppointmentDate], 2 )
		formatString: 0
		lineageTag: a264aeb1-7f88-4037-9a26-37ac5ee58f5d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column is_live =
			
			COALESCE (
			    'AS_Result_Schedule_Activity'[is_live_shipment],
			    'AS_Result_Schedule_Activity'[is_live_receipt]
			    )
		lineageTag: fbfe6695-b822-472a-9a35-6948c3d4e7a5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column ActionKey =
			
			VAR _site  = COALESCE ( 'AS_Result_Schedule_Activity'[site_id], "" )
			VAR _act   = COALESCE ( 'AS_Result_Schedule_Activity'[action_id], "" )
			VAR _actor = COALESCE ( 'AS_Result_Schedule_Activity'[actor_id], "" )
			VAR _equip = COALESCE ( 'AS_Result_Schedule_Activity'[equipment_id], "" )
			VAR _to    = COALESCE ( 'AS_Result_Schedule_Activity'[to_movement_id], "" )
			VAR _from  = COALESCE ( 'AS_Result_Schedule_Activity'[from_movement_id], "" )
			VAR _start = 'AS_Result_Schedule_Activity'[start_utc]
			VAR _startT = IF ( ISBLANK(_start), "", FORMAT ( _start, "yyyy-MM-dd HH:mm:ss" ) )
			RETURN
			    _site & "|" & _act & "|" & _actor & "|" & _equip &  "|" & _startT
		lineageTag: af06ecec-e95a-4124-a7a6-624cc94832c4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MovementKey =
			
			VAR site = COALESCE ( 'AS_Result_Schedule_Activity'[site_id], "" )
			VAR ship = 'AS_Result_Schedule_Activity'[shipment_id]
			VAR rcpt = 'AS_Result_Schedule_Activity'[receipt_id]
			VAR typ  = IF( NOT ISBLANK(ship), "SHIP", IF( NOT ISBLANK(rcpt), "RCPT", "NA" ) )
			VAR mk   = COALESCE ( ship, rcpt )
			RETURN IF( ISBLANK(mk), BLANK(), site & "|" & typ & "|" & mk )
		lineageTag: 280f3d95-a63c-4d55-b2a3-afdd1a3a791c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Ended_Any =
			
			COALESCE(
			    'AS_Result_Schedule_Activity'[ended_shipment],
			    'AS_Result_Schedule_Activity'[ended_receipt]
			)
