	column 'Proposed Door' =
			
			VAR lbl = UPPER( TRIM ( 'AS_Result_Schedule_Activity'[MoveTypeLab] & "" ) )
			
			VAR r0  = 'AS_Result_Schedule_Activity'[Door_Proposed_Receipt]
			VAR s0  = 'AS_Result_Schedule_Activity'[Door_Proposed_Shipment]
			VAR ra0 = 'AS_Result_Schedule_Activity'[door_id_assigned_receipt]
			VAR sa0 = 'AS_Result_Schedule_Activity'[door_id_assigned_shipment]
			
			VAR r  = IF( LEN( TRIM( r0 & "" ) ) = 0, BLANK(), r0 )
			VAR s  = IF( LEN( TRIM( s0 & "" ) ) = 0, BLANK(), s0 )
			VAR ra = IF( LEN( TRIM( ra0 & "" ) ) = 0, BLANK(), ra0 )
			VAR sa = IF( LEN( TRIM( sa0 & "" ) ) = 0, BLANK(), sa0 )
			
			VAR leftDoor  = COALESCE( r,  ra )
			VAR rightDoor = COALESCE( s,  sa )
			
			RETURN
			IF (
			    lbl = "CROSSDOCK",
			    IF ( NOT ISBLANK(leftDoor) && NOT ISBLANK(rightDoor),
			         leftDoor & " -> " & rightDoor,
			         COALESCE(leftDoor, rightDoor)
			    ),
			    COALESCE(leftDoor, rightDoor)
			)
		lineageTag: 4a8ab76a-4b88-4d4e-a5cc-8647792cde05
		summarizeBy: none

