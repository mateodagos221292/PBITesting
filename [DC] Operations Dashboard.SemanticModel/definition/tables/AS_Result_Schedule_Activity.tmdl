	column NextStartOrEnd_UTC =
			
			IF (
			    AS_Result_Schedule_Activity[MinStart_UTC] >= UTCNOW(),
			    AS_Result_Schedule_Activity[MinStart_UTC],
			    AS_Result_Schedule_Activity[MaxEnd_UTC]
			)
		formatString: m/d/yyyy h:nn:ss AM/PM
		lineageTag: f554149b-c124-4317-af2c-1c33f00146c2
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 1a793d6d-6764-4d3b-a087-a5851984ab54
			defaultHierarchy: LocalDateTable_48531291-6be8-4660-95df-02ffc6d7e035.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	column NextDoType = ```
			
			VAR statusBasicVal = 'AS_Result_Schedule_Activity'[Status_Basic]
			VAR nextTime = 'AS_Result_Schedule_Activity'[NextStartOrEnd_UTC]
			VAR startTime = 'AS_Result_Schedule_Activity'[MinStart_UTC]
			VAR endTime   = 'AS_Result_Schedule_Activity'[MaxEnd_UTC]
			RETURN
			SWITCH(
			    TRUE(),
			    statusBasicVal = "Not started" && isblank(startTime), "Wait", -- wait if not scheduled. 
			    statusBasicVal = "Completed", "Completed",
			    statusBasicVal = "In Progress" && endTime <= nextTime, "Finish",
			    statusBasicVal = "In Progress" && endTime > nextTime, "Continue",
			    statusBasicVal = "Not started" && startTime <= UTCNOW() + (1/24) , "Start", --start if sched start withing next hour
			    statusBasicVal = "Not started" && startTime > UTCNOW() + (1/24), "Wait", -- wait if schedstart more than 1 hour. 
			    BLANK()
			)
			```
		lineageTag: a9c5c8e2-63eb-4d18-812d-e4f4d9483094
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MoveTypeLab =
			
			SWITCH(
			    TRUE(),
			    AS_Result_Schedule_Activity[from_movement_type] = "production"
			        && AS_Result_Schedule_Activity[to_movement_type] = "shipment",        "Express from production",
			
			    AS_Result_Schedule_Activity[from_movement_type] = "receipt"
			        && AS_Result_Schedule_Activity[to_movement_type] = "#unknown",        "Receipt to storage",
			
			    AS_Result_Schedule_Activity[from_movement_type] = "production"
			        && AS_Result_Schedule_Activity[to_movement_type] = "#unknown",        "Production to storage",
			
			    AS_Result_Schedule_Activity[from_movement_type] = "#unknown"
			        && AS_Result_Schedule_Activity[to_movement_type] = "shipment",        "Shipment from storage",
			
			    AS_Result_Schedule_Activity[from_movement_type] = "#unknown"
			        && AS_Result_Schedule_Activity[to_movement_type] = "consumption",     "Consumption from storage",
			
			    AS_Result_Schedule_Activity[from_movement_type] = "receipt"
			        && AS_Result_Schedule_Activity[to_movement_type] = "consumption",     "Receipt to consumption",
			
			    AS_Result_Schedule_Activity[from_movement_type] = "receipt"
			        && AS_Result_Schedule_Activity[to_movement_type] = "shipment",        "Crossdock",
			
			    "Check"
			)
		lineageTag: fe717e15-d324-4bdd-b0b6-862e98de0dc5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MoveID = ```
			
			SWITCH(
			    TRUE(),
			    -- If from is unknown → use to_movement_id
			    AS_Result_Schedule_Activity[from_movement_id] = "#unknown",
			        AS_Result_Schedule_Activity[to_movement_id],
			
			    -- If to is unknown → use from_movement_id
			    AS_Result_Schedule_Activity[MoveTypeLab] = "Receipt to storage",
			        AS_Result_Schedule_Activity[from_movement_id],
			
			    -- If MoveTypeLabel = 'Express from production' → use to_movement_id
			    AS_Result_Schedule_Activity[MoveTypeLab] = "Express from production",
			        AS_Result_Schedule_Activity[to_movement_id],
			
			    AS_Result_Schedule_Activity[MoveTypeLab] = "Production to storage",
			        AS_Result_Schedule_Activity[from_movement_id],
			    
			    AS_Result_Schedule_Activity[MoveTypeLab] = "Receipt to Consumption",
			        AS_Result_Schedule_Activity[from_movement_id],
			    -- Otherwise → concatenate both
			    AS_Result_Schedule_Activity[MoveTypeLab] = "Crossdock",
			        AS_Result_Schedule_Activity[from_movement_id] & " → " & AS_Result_Schedule_Activity[to_movement_id],
			    
			    Coalesce(AS_Result_Schedule_Activity[from_movement_id] , AS_Result_Schedule_Activity[to_movement_id])
			)
			```
		lineageTag: e3ea29bb-37f1-409d-85e4-f3fbaa858d3e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Door_Proposed_Receipt
		dataType: string
		lineageTag: fda5a6c1-7381-4b1b-8fd8-ecbcbeead4d0
		summarizeBy: none
		sourceColumn: Door_Proposed_Receipt

		annotation SummarizationSetBy = Automatic

	column AssignedDoor =
			
			VAR lbl =
			    UPPER( TRIM ( 'AS_Result_Schedule_Activity'[MoveTypeLab] & "" ) )
			
			VAR r0 = 'AS_Result_Schedule_Activity'[door_id_assigned_receipt]
			VAR s0 = 'AS_Result_Schedule_Activity'[door_id_assigned_shipment]
			
			-- normalize blanks
			VAR r  = IF( LEN( TRIM( r0 & "" ) ) = 0, BLANK(), r0 )
			VAR s  = IF( LEN( TRIM( s0 & "" ) ) = 0, BLANK(), s0 )
			
			RETURN
			IF (
			    lbl = "CROSSDOCK",
			    IF ( NOT ISBLANK(r) && NOT ISBLANK(s), r & " -> " & s, COALESCE(r, s) ),
			    COALESCE(r, s)
			)
		lineageTag: 9e9a5da7-9fd6-432d-907e-2a7aca1ee1bf
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column NextDoType_Move =
			
			VAR StartWindowMin = 120    -- @start_now_horizon_minutes
			VAR EndWindowMin   = 120   -- @end_now_horizon_minutes
			VAR NowUtc         = UTCNOW()
			VAR StartWindowEnd = NowUtc + (StartWindowMin / 1440.0)
			VAR EndWindowEnd   = NowUtc + (EndWindowMin   / 1440.0)
			
			VAR HasShipment    = NOT ISBLANK ( AS_Result_Schedule_Activity[to_movement_id] )
			VAR HasReceipt     = NOT ISBLANK ( AS_Result_Schedule_Activity[from_movement_id] )
			
			VAR ShipStarted    = NOT ISBLANK ( AS_Result_Schedule_Activity[start_utc] )
			VAR ShipEnded      = NOT ISBLANK ( AS_Result_Schedule_Activity[ended_shipment] )
			VAR RcptStarted    = NOT ISBLANK ( AS_Result_Schedule_Activity[started_receipt] )
			VAR RcptEnded      = NOT ISBLANK ( AS_Result_Schedule_Activity[ended_utc_receipt] )
			
			VAR MinStartUTC    = AS_Result_schedule_activity[MinStart_UTC]
			VAR MaxEndUTC      = AS_Result_schedule_activity[MaxEnd_UTC]
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    // shipment: not started, start window
			    HasShipment && NOT ShipStarted && MinStartUTC <= StartWindowEnd, "Start",
			
			    // shipment: in progress, end window
			    HasShipment && ShipStarted && NOT ShipEnded && MaxEndUTC <= EndWindowEnd, "Finish",
			
			    // receipt: not started, start window
			    HasReceipt && NOT RcptStarted && MinStartUTC <= StartWindowEnd, "Start",
			
			    // receipt: in progress, end window
			    HasReceipt && RcptStarted && NOT RcptEnded && MaxEndUTC <= EndWindowEnd, "Finish",
			
			    // completed states
			    ShipStarted && ShipEnded, "Completed",
			    RcptStarted && RcptEnded, "Completed",
			
			    // no live status for prod/consumption
			    (AS_Result_schedule_activity[from_movement_type] = "production"
			        && AS_Result_schedule_activity[to_movement_type] = "#unknown")
			        || (AS_Result_schedule_activity[from_movement_type] = "#unknown"
			        && AS_Result_schedule_activity[to_movement_type] = "consumption"),
			        "Dont have live status of production or consumption",
			
			    // default
			    "Wait"
			)
		lineageTag: 29b332e7-1f7b-42e7-a957-5a086fab93f8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column DetentionFlag =
			
			VAR IsLiveShip =
			    IF( AS_Result_schedule_activity[is_live_shipment] IN { TRUE(), "True" }, TRUE(), FALSE() )
			
			VAR ReceiptPaidDet =
			    NOT ISBLANK( AS_Result_schedule_activity[ended_utc_receipt] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_receipt] ) &&
			    AS_Result_schedule_activity[ended_utc_receipt] >= AS_Result_schedule_activity[late_after_utc_receipt]
			
			VAR ShipmentPaidDet =
			    NOT ISBLANK( AS_Result_schedule_activity[ended_utc_shipment] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_shipment] ) &&
			    AS_Result_schedule_activity[ended_utc_shipment] >= AS_Result_schedule_activity[late_after_utc_shipment] &&
			    IsLiveShip
			
			VAR ReceiptExpectDet =
			    NOT ISBLANK( AS_Result_schedule_activity[end_utc] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_receipt] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[receipt_id] ) &&
			    AS_Result_schedule_activity[end_utc] >= AS_Result_schedule_activity[late_after_utc_receipt]
			
			VAR ShipmentExpectDet =
			    NOT ISBLANK( AS_Result_schedule_activity[end_utc] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_shipment] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[shipment_type_id] ) &&
			    IsLiveShip &&
			    AS_Result_schedule_activity[end_utc] >= AS_Result_schedule_activity[late_after_utc_shipment]
			
			RETURN
			SWITCH(
			    TRUE(),
			    ReceiptPaidDet || ShipmentPaidDet, "Paid",
			    ReceiptExpectDet || ShipmentExpectDet, "Expected",
			    "No"
			)
		lineageTag: d51fc346-5179-4d7a-84d7-ab4d8d418dbf
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column LateFlag =
			
			VAR ReceiptLatePast =
			    NOT ISBLANK( AS_Result_schedule_activity[ended_utc_receipt] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_receipt] ) &&
			    AS_Result_schedule_activity[ended_utc_receipt] >= AS_Result_schedule_activity[late_after_utc_receipt]
			
			VAR ShipmentLatePast =
			    NOT ISBLANK( AS_Result_schedule_activity[ended_utc_shipment] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_shipment] ) &&
			    AS_Result_schedule_activity[ended_utc_shipment] >= AS_Result_schedule_activity[late_after_utc_shipment]
			
			VAR ReceiptExpectLate =
			    NOT ISBLANK( AS_Result_schedule_activity[end_utc] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_receipt] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[receipt_id] ) &&
			    AS_Result_schedule_activity[end_utc] >= AS_Result_schedule_activity[late_after_utc_receipt]
			
			VAR ShipmentExpectLate =
			    NOT ISBLANK( AS_Result_schedule_activity[end_utc] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[late_after_utc_shipment] ) &&
			    NOT ISBLANK( AS_Result_schedule_activity[shipment_id] ) &&
			    AS_Result_schedule_activity[end_utc] >= AS_Result_schedule_activity[late_after_utc_shipment]
			
			RETURN
			SWITCH(
			    TRUE(),
			    ReceiptLatePast || ShipmentLatePast, "Late in Past",
			    ReceiptExpectLate || ShipmentExpectLate, "Expect Late",
			    "Not Late"
			)
		lineageTag: e8c7cf84-0d49-4f98-91f8-e610d1d2621d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

