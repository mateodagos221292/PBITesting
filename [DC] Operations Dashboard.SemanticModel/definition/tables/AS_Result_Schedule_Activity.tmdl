	measure Cases = ```
			
			DIVIDE (
			    SUM ( 'AS_Result_Schedule_Activity'[Cases_Expected_Ordered] ),   
			    [Distinct Rows],
			    0
			)
			```
		lineageTag: ef575ce8-d631-43f0-ac0d-9ff7d0336085

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cases_Expected_Ordered (Distinct Movements)' =
			
			SUMX(
			    VALUES( 'AS_Result_Schedule_Activity'[MovementKey] ),
			    CALCULATE( MAX( 'AS_Result_Schedule_Activity'[Cases_Expected_Ordered] ) )
			)
		formatString: #,0
		lineageTag: 4ef07cc1-5511-4bac-b8e8-cc98d83692e7

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Cases_Recevied_Loaded (Distinct Movements)' =
			
			SUMX(
			    VALUES( 'AS_Result_Schedule_Activity'[MovementKey] ),
			    CALCULATE( MAX( 'AS_Result_Schedule_Activity'[Cases_Recevied_Loaded] ) )
			)
		lineageTag: 0e36757a-fbeb-4c86-bda8-c940dd679112

