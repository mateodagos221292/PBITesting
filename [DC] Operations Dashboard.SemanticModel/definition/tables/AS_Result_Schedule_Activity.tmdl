	measure SelectedWindowText =
			
			"Showing moves starting or ending in the next " &
			FORMAT(SELECTEDVALUE(TimeHorizonHours[Value], 8), "#") & " hours"
		lineageTag: 830e0ae9-be67-4473-bbaa-cbe2e704b7a2

	measure IsWithinNextXHours_UTC =
			
			VAR nextTime = MAX(AS_Result_Schedule_Activity[NextStartorEnd_UTC])
			VAR nowTime  = UTCNOW()
			VAR horizon  = [HoursAhead Selected]
			RETURN
			    IF(
			        NOT ISBLANK(nextTime) &&
			        nextTime >= nowTime &&
			        nextTime <= nowTime + (horizon / 24.0),
			        1,
			        0
			    )
		formatString: 0
		lineageTag: 15cd74c8-6cfe-43dd-881f-be19c7706915

