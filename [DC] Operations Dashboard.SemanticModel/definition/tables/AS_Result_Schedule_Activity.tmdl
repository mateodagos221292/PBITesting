	measure Status =
			
			VAR HoursAhead = COALESCE( SELECTEDVALUE(TimeHorizonHours[Value]), 4 )
			VAR nowUTC     = UTCNOW()
			
			-- identify row type
			VAR ShipID = MAX('AS_Result_Schedule_Activity'[shipment_type_id])
			VAR RcptID = MAX('AS_Result_Schedule_Activity'[receipt_id])
			VAR IsShip = NOT ISBLANK(ShipID)
			VAR IsRcpt = NOT ISBLANK(RcptID)
			
			-- base timestamps (use MAX to avoid SELECTEDVALUE ambiguity)
			VAR StartUTC       = MAX('AS_Result_Schedule_Activity'[start_utc])
			VAR EndUTC         = MAX('AS_Result_Schedule_Activity'[end_utc])
			
			VAR ShipStartUTC   = MAX('AS_Result_Schedule_Activity'[started_utc_shipment])
			VAR ShipEndUTC     = MAX('AS_Result_Schedule_Activity'[ended_utc_shipment])
			VAR ShipLateUTC    = MAX('AS_Result_Schedule_Activity'[late_after_utc_shipment])
			
			VAR RcptStartUTC   = MAX('AS_Result_Schedule_Activity'[started_utc_receipt])
			VAR RcptEndUTC     = MAX('AS_Result_Schedule_Activity'[ended_utc_receipt])
			VAR RcptLateUTC    = MAX('AS_Result_Schedule_Activity'[late_after_utc_receipt])
			-- add this near the top, after we define other receipt vars
			VAR RcptExpectedBUOM = MAX('AS_Result_Schedule_Activity'[expected_buom])
			VAR IsUnexpectedRcpt = IsRcpt && COALESCE(RcptExpectedBUOM,0) = 0
			
			-- in-full (adjust column names if your receipt uses expected/received)
			VAR ShipOrdered    = MAX('AS_Result_Schedule_Activity'[ordered_buom])
			VAR ShipLoaded     = MAX('AS_Result_Schedule_Activity'[loaded_buom])
			VAR RcptExpected    = MAX('AS_Result_Schedule_Activity'[expected_buom])
			VAR RcptReceived     = MAX('AS_Result_Schedule_Activity'[received_buom])
			
			VAR InFullShip     = IF( NOT ISBLANK(ShipOrdered), IF( ShipLoaded >= ShipOrdered, "Full", "Partial" ) )
			VAR InFullRcpt     = IF( NOT ISBLANK(RcptExpected), IF( RcptReceived >= RcptExpected, "Full", "Partial" ) )
			
			-- hours (compute inline, clamp negatives to 0 so “soon” logic works)
			VAR HrsToStart     = IF( ISBLANK(StartUTC), BLANK(), MAX(0, DATEDIFF(nowUTC, StartUTC, MINUTE) / 60.0) )
			VAR HrsToEnd       = IF( ISBLANK(EndUTC),   BLANK(), MAX(0, DATEDIFF(nowUTC, EndUTC,   MINUTE) / 60.0) )
			
			VAR HrsSinceShip   = IF( ISBLANK(ShipStartUTC), BLANK(), DATEDIFF(ShipStartUTC, nowUTC, MINUTE) / 60.0 )
			VAR HrsSinceRcpt   = IF( ISBLANK(RcptStartUTC), BLANK(), DATEDIFF(RcptStartUTC, nowUTC, MINUTE) / 60.0 )
			
			VAR HrsTillLateShip= IF( ISBLANK(ShipLateUTC), BLANK(), MAX(0, DATEDIFF(nowUTC, ShipLateUTC, MINUTE) / 60.0) )
			VAR HrsTillLateRcpt= IF( ISBLANK(RcptLateUTC), BLANK(), MAX(0, DATEDIFF(nowUTC, RcptLateUTC, MINUTE) / 60.0) )
			
			-- state checks
			VAR ShipInProgress   = IsShip && NOT ISBLANK(HrsSinceShip) && ISBLANK(ShipEndUTC)
			VAR RcptInProgress   = IsRcpt && NOT ISBLANK(HrsSinceRcpt) && ISBLANK(RcptEndUTC)
			
			VAR ShipScheduledSoon= IsShip && ISBLANK(HrsSinceShip) && NOT ISBLANK(HrsToStart) && HrsToStart <= HoursAhead
			VAR RcptScheduledSoon= IsRcpt && ISBLANK(HrsSinceRcpt) && NOT ISBLANK(HrsToStart) && HrsToStart <= HoursAhead
			
			VAR ShipCompleted    = IsShip && NOT ISBLANK(ShipEndUTC)
			VAR RcptCompleted    = IsRcpt && NOT ISBLANK(RcptEndUTC)
			
			VAR ShipOnTime       = IF( ShipCompleted && NOT ISBLANK(ShipLateUTC), ShipEndUTC <= ShipLateUTC )
			VAR RcptOnTime       = IF( RcptCompleted && NOT ISBLANK(RcptLateUTC), RcptEndUTC <= RcptLateUTC )
			
			VAR ShipExpectedLate = IsShip && ISBLANK(ShipEndUTC) && NOT ISBLANK(HrsTillLateShip) && HrsTillLateShip <= HoursAhead
			VAR RcptExpectedLate = IsRcpt && ISBLANK(RcptEndUTC) && NOT ISBLANK(HrsTillLateRcpt) && HrsTillLateRcpt <= HoursAhead
			
			RETURN
			SWITCH(
			    TRUE(),
			    -- Receipt unexpected (completed, in progress, or scheduled)
			    IsUnexpectedRcpt && RcptCompleted, "Receipt unexpected",
			    IsUnexpectedRcpt && RcptInProgress, "Receipt unexpected (in progress)",
			    IsUnexpectedRcpt && RcptScheduledSoon, "Receipt unexpected (scheduled)",
			    -- In progress
			    ShipInProgress, "Shipment in progress",
			    RcptInProgress, "Receipt in progress",
			
			    -- Scheduled soon (within horizon)
			    ShipScheduledSoon, "Shipment scheduled to start soon",
			    RcptScheduledSoon, "Receipt scheduled to start soon",
			
			    -- Completed (on time / late; full / partial)
			    ShipCompleted && ShipOnTime && InFullShip = "Full",      "Shipment completed on time in full",
			    ShipCompleted && NOT ShipOnTime && InFullShip = "Full",  "Shipment completed late in full",
			    ShipCompleted && ShipOnTime && InFullShip = "Partial",   "Shipment completed on time partially",
			    ShipCompleted && NOT ShipOnTime && InFullShip = "Partial","Shipment completed late partially",
			
			    RcptCompleted && RcptOnTime && InFullRcpt = "Full",      "Receipt completed on time in full",
			    RcptCompleted && NOT RcptOnTime && InFullRcpt = "Full",  "Receipt completed late in full",
			    RcptCompleted && RcptOnTime && InFullRcpt = "Partial",   "Receipt completed on time partially",
			    RcptCompleted && NOT RcptOnTime && InFullRcpt = "Partial","Receipt completed late partially",
			
			    -- Expected late (within horizon)
			    ShipExpectedLate, "Shipment expected out late",
			    RcptExpectedLate, "Receipt expected to arrive late",
			
			    -- Fallback
			    "Shipment/receipt — wait on this"
			)
		lineageTag: 57a5e856-c2a3-4730-b540-c5832f81b9f0

	measure Hours_till_late =
			
			VAR ship = [Hours_till_late_Shipment]
			VAR rcpt = [Hours_till_late_Receipt]
			RETURN COALESCE(ship, rcpt)
		lineageTag: 2b0a204f-e90a-4e31-a937-e0a81b166f80

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Hours_late =
			
			VAR t = [Hours_till_late]       -- uses the measure above
			RETURN IF( ISBLANK(t), BLANK(), IF( t < 0, ABS(t), 0 ) )
		lineageTag: 9488375f-ce13-4656-9ff4-94aeab539281

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Amount_Short_Receipt = ```
			
			VAR expected = COALESCE(
			    SELECTEDVALUE(AS_Result_Schedule_Activity[expected_ULs]),
			    SELECTEDVALUE(AS_Result_Schedule_Activity[received_ULs])  -- optional fallback
			)
			VAR actual = COALESCE(
			    SELECTEDVALUE(AS_Result_Schedule_Activity[received_ULs]),
			    SELECTEDVALUE(AS_Result_Schedule_Activity[received_ULs])   -- optional fallback
			)
			RETURN IF( ISBLANK(expected), BLANK(), MAX(0, expected - COALESCE(actual, 0)) )
			
			```
		lineageTag: ce3ef7f7-0539-44e3-bf55-8e31a7f1434f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Amount_Short_Shipment = ```
			
			VAR orderedd = SELECTEDVALUE(AS_Result_Schedule_Activity[ordered_ULs])
			VAR loaded  = SELECTEDVALUE(AS_Result_Schedule_Activity[loaded_ULs])
			RETURN IF( ISBLANK(orderedd), BLANK(), MAX(0, orderedd - COALESCE(loaded, 0)) )
			
			```
		lineageTag: 73206ebe-0f33-4452-826f-61e34ff993c9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Amount_Short/Left =
			
			COALESCE( [Amount_Short_Shipment], [Amount_Short_Receipt] )
		lineageTag: 7a6fcc16-f028-484b-8b68-66c57da3bd79

	measure Time_till_late =
			
			VAR IsCompleted =
			    SELECTEDVALUE ( 'AS_Result_Schedule_Activity'[Status_Basic] ) = "Completed"
			
			VAR HoursMax =
			    MAXX (
			        VALUES ( 'AS_Result_Schedule_Activity'[action_id] ),
			        [Hours_till_late]
			    )
			VAR TotalMinutes = HoursMax * 60
			VAR SignPart    = IF ( TotalMinutes < 0, "-", "" )
			VAR HoursPart   = INT ( ABS ( TotalMinutes ) / 60 )
			VAR MinutesPart = MOD ( ABS ( TotalMinutes ), 60 )
			
			RETURN
			IF (
			    IsCompleted,
			    BLANK(),
			    SignPart & FORMAT ( HoursPart, "0" ) & ":" & FORMAT ( MinutesPart, "00" )
			)
		lineageTag: 40732647-0145-4244-a9e0-63dee2c2ba8c

	measure IsWithinNextXHours =
			
			VAR nextTime = MAX(AS_Result_Schedule_Activity[NextStartorEnd])
			VAR nowTime  = NOW()
			VAR horizon  = [HoursAhead Selected]
			RETURN
			    IF(
			        NOT ISBLANK(nextTime) &&
			        nextTime >= nowTime &&
			        nextTime <= nowTime + (horizon / 24.0),
			        1,
			        0
			    )
		formatString: 0
		lineageTag: ceb6a849-cc87-4862-873d-d63775c1a39f

	measure PctProgress =
			
			VAR statusVal =
			    MAX ( 'AS_Result_Schedule_Activity'[Status_Basic] )
			VAR pct =
			    DIVIDE (
			        SUM ( 'AS_Result_Schedule_Activity'[Cases_Received_Loaded] ),
			        SUM ( 'AS_Result_Schedule_Activity'[Cases_Expected_Ordered] ),
			        0
			    )
			RETURN
			IF ( statusVal = "Completed", pct, pct )
		formatString: 0%;-0%;0%
		lineageTag: ce836685-3ba8-42fa-84ff-ee3f1274eb9c

