	column Time_till_late_minutes =
			
			VAR IsCompleted = 'AS_Result_Schedule_Activity'[Status_Basic] = "Completed"
			VAR HoursMax =
			    MAXX (
			        VALUES ( 'AS_Result_Schedule_Activity'[action_id] ),
			        [Hours_till_late]
			    )
			RETURN
			IF ( IsCompleted, BLANK(), (HoursMax * 60)/60.0 )
		lineageTag: 66772bbd-1462-4fc5-8838-a537b4acdb89
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Time_till_late_label
		type: calculated
		lineageTag: aaff1664-c948-4b6d-9441-b3bc6bddbc5b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":"\nVAR IsCompleted = 'AS_Result_Schedule_Activity'[Status_Basic] = \"Completed\"\nVAR HoursMax =\n    MAXX (\n        VALUES ( 'AS_Result_Schedule_Activity'[action_id] ),\n        [Hours_till_late]\n    )\nVAR Minutes = IF ( IsCompleted, BLANK(), HoursMax * 60 )\nVAR SortKey = RIGHT ( \"000000\" & FORMAT ( Minutes, \"0\" ), 6 )\nVAR Label =\n    IF ( IsCompleted, BLANK(),\n        FORMAT ( INT ( Minutes / 60 ), \"0\" ) & \":\" & FORMAT ( MOD ( Minutes, 60 ), \"00\" )\n    )\nRETURN SortKey & \" | \" & Label"}

		annotation 277cc1b9-af89-4597-8e15-cacc25c0886b = ```
				A circular dependency was detected: AS_Result_Schedule_Activity[Time_till_late_label], AS_Result_Schedule_Activity[Time_till_late_minutes], AS_Result_Schedule_Activity[Time_till_late_label].
				
				```

	partition AS_Result_Schedule_Activity = m
		mode: import
		source = ```
				let
				    #"Merge Activity with DoorAssignment for shipments" = Table.NestedJoin(AS_Result_Schedule_Activity_Data, {"site_id", "to_movement_id"}, AS_Result_Door_Assignment, {"site_id", "movement_id"}, "AS_Result_Door_Assignment", JoinKind.LeftOuter),
				    #"Expanded AS_Result_Door_Assignment" = Table.ExpandTableColumn(#"Merge Activity with DoorAssignment for shipments", "AS_Result_Door_Assignment", {"door_id"}, {"Door_Proposed_shipment"}),
				    #"Merge Activity with Door Assignment for Receipts" = Table.NestedJoin(#"Expanded AS_Result_Door_Assignment", {"site_id", "from_movement_id"}, AS_Result_Door_Assignment, {"site_id", "movement_id"}, "AS_Result_Door_Assignment", JoinKind.LeftOuter),
				    #"Expanded AS_Result_Door_Assignment1" = Table.ExpandTableColumn(#"Merge Activity with Door Assignment for Receipts", "AS_Result_Door_Assignment", {"door_id"}, {"door_id"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Expanded AS_Result_Door_Assignment1",{{"door_id", "Door_Proposed_Receipt"}}),
				    
				LeftKeysNormalized =
				    Table.TransformColumns(
				        #"Renamed Columns",
				        {
				            {"site_id",          each Text.Upper(Text.Trim(Text.From(_))), type text},
				            {"to_movement_id",   each Text.Upper(Text.Trim(Text.From(_))), type text},
				            {"from_movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				        }
				    ),
				    
				
				// 2) Normalize keys on Shipments log (AS_Shipments_Log)
				    ShipLogKeys =
				        Table.TransformColumns(
				            AS_Shipments_Log,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"shipment_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				    ),
				
				// 3) Normalize keys on Receipts log (AS_Receipts_Log)
				    RcptLogKeys =
				        Table.TransformColumns(
				            AS_Receipts_Log,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"receipt_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				    ),
				
				// 4) Filter for SHIPMENTS merge only (do NOT filter from_movement_id here)
				    LeftForShip =
				        //Table.SelectRows(LeftKeysNormalized, each [to_movement_id] <> "#UNKNOWN"),
				         LeftKeysNormalized,
				
				// 5) Merge Shipments
				    Merged_Ship =
				        Table.NestedJoin(
				            LeftForShip, {"site_id","to_movement_id"},
				            ShipLogKeys, {"site_id","shipment_id"},
				            "ShipLog", JoinKind.LeftOuter
				    ),
				    Expanded_Ship =
				        Table.ExpandTableColumn(
				            Merged_Ship, "ShipLog",
				            {"shipment_id","shipment_type_id","customers","note","is_live","planned_arrival_utc","planned_arrival","arrived_utc","arrived","appointment_date_utc","appointment_date","late_after_utc","late_after","transportation_type_id","started_utc","started","ended_utc","ended","last_scheduled_end_utc","last_scheduled_end","carrier_id","trailer_id","orders","ordered_items","ordered_buom","ordered_cases","ordered_ULs","ordered_kg","ordered_weight","ordered_weight_uom","ordered_cm3","ordered_volume","ordered_volume_uom","loaded_items","loaded_buom","loaded_cases","loaded_ULs","loaded_kg","loaded_weight","loaded_weight_uom","loaded_cm3","loaded_volume","loaded_volume_uom","door_id"},
				            {"shipment_id","shipment_type_id","customers","note","is_live","planned_arrival_utc","planned_arrival","arrived_utc","arrived","appointment_date_utc","appointment_date","late_after_utc","late_after","transportation_type_id","started_utc","started","ended_utc","ended","last_scheduled_end_utc","last_scheduled_end","carrier_id","trailer_id","orders","ordered_items","ordered_buom","ordered_cases","ordered_ULs","ordered_kg","ordered_weight","ordered_weight_uom","ordered_cm3","ordered_volume","ordered_volume_uom","loaded_items","loaded_buom","loaded_cases","loaded_ULs","loaded_kg","loaded_weight","loaded_weight_uom","loaded_cm3","loaded_volume","loaded_volume_uom","door_id.s"}
				    ),
				
				// 6) Now filter for RECEIPTS merge (do NOT filter to_movement_id here)
				    LeftForRcpt = Expanded_Ship,   // 7) Merge Receipts
				    Merged_Rcpt =
				        Table.NestedJoin(
				            LeftForRcpt, {"site_id","from_movement_id"},
				            RcptLogKeys, {"site_id","receipt_id"},
				            "RcptLog", JoinKind.LeftOuter
				    ),
				    Expanded_Rcpt =
				        Table.ExpandTableColumn(
				            Merged_Rcpt, "RcptLog",
				            {"receipt_id","receipt_type_id","origin","note","is_live","planned_arrival_utc","planned_arrival","arrived_utc","arrived","late_after_utc","late_after","appointment_date_utc","appointment_date","transportation_type_id","started_utc","started","ended_utc","ended","carrier_id","trailer_id","door_id","expected_items","expected_buom","expected_cases","expected_ULs","expected_kg","expected_weight","expected_weight_uom","expected_cm3","expected_volume","expected_volume_uom","received_items","received_buom","received_cases","received_ULs","received_kg","received_weight","received_weight_uom","received_cm3","received_volume","received_volume_uom","ignore","ignore_unless_hot"},
				            {"receipt_id","receipt_type_id","origin","note.1","is_live.1","planned_arrival_utc.1","planned_arrival.1","arrived_utc.1","arrived.1","late_after_utc.1","late_after.1","appointment_date_utc.1","appointment_date.1","transportation_type_id.1","started_utc.1","started.1","ended_utc.1","ended.1","carrier_id.1","trailer_id.1","door_id.r","expected_items","expected_buom","expected_cases","expected_ULs","expected_kg","expected_weight","expected_weight_uom","expected_cm3","expected_volume","expected_volume_uom","received_items","received_buom","received_cases","received_ULs","received_kg","received_weight","received_weight_uom","received_cm3","received_volume","received_volume_uom","ignore","ignore_unless_hot"}
				    ),
				    #"Renamed Columns all" = Table.RenameColumns(#"Expanded_Rcpt",
				    {
				        {"appointment_date", "appointment_date_shipment"},
				        {"appointment_date_utc", "appointment_date_utc_shipment"},
				        {"carrier_id", "carrier_id_shipment"},
				        {"ended", "ended_shipment"},
				        {"ended_utc", "ended_utc_shipment"},
				        {"is_live", "is_live_shipment"},
				        {"note", "note_shipment"},
				        {"late_after", "late_after_shipment"},
				        {"late_after_utc", "late_after_utc_shipment"},
				        {"planned_arrival", "planned_arrival_shipment"},
				        {"planned_arrival_utc", "planned_arrival_utc_shipment"},
				        {"started", "started_shipment"},
				        {"started_utc", "started_utc_shipment"},
				        {"arrived", "arrived_shipment"},
				        {"arrived_utc", "arrived_utc_shipment"},
				        {"trailer_id", "trailer_id_shipment"},
				        {"transportation_type_id", "transportation_type_shipment"},
				        {"appointment_date.1", "appointment_date_receipt"},
				        {"appointment_date_utc.1", "appointment_date_utc_receipt"},
				        {"carrier_id.1", "carrier_id_receipt"},
				        {"ended.1", "ended_receipt"},
				        {"ended_utc.1", "ended_utc_receipt"},
				        {"is_live.1", "is_live_receipt"},
				        {"note.1", "note_receipt"},
				        {"late_after.1", "late_after_receipt"},
				        {"late_after_utc.1", "late_after_utc_receipt"},
				        {"planned_arrival.1", "planned_arrival_receipt"},
				        {"planned_arrival_utc.1", "planned_arrival_utc_receipt"},
				        {"started.1", "started_receipt"},
				        {"started_utc.1", "started_utc_receipt"},
				        {"arrived.1", "arrived_receipt"},
				        {"arrived_utc.1", "arrived_utc_receipt"},
				        {"trailer_id.1", "trailer_id_receipt"},
				        {"transportation_type_id.1", "transportation_type_receipt"},
				        {"door_id.r", "door_id_assigned_receipt"},
				        {"door_id.s", "door_id_assigned_shipment"},
				        {"door_id", "door_id_proposed"}
				    },
				    MissingField.Ignore
				    ),
				    // normalize keys on the LEFT side used for the aggregates join
				    LeftForAgg =
				        Table.TransformColumns(
				            #"Renamed Columns all",
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"to_movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"from_movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				// normalize keys on the RIGHT side (AS_Schedule_Aggregates)
				    AggKeys =
				        Table.TransformColumns(
				            AS_Schedule_Aggregates,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"to_movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"from_movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				// join
				    MergedAgg =
				        Table.NestedJoin(
				            LeftForAgg, {"site_id","to_movement_id","from_movement_id"},
				            AggKeys,    {"site_id","to_movement_id","from_movement_id"},
				            "Agg", JoinKind.LeftOuter
				    ),
				    ExpandedAgg =
				        Table.ExpandTableColumn(MergedAgg, "Agg", {"MinStart_UTC", "MaxEnd_UTC", "MinStart", "MaxEnd"}, {"MinStart_UTC", "MaxEnd_UTC", "MinStart", "MaxEnd"}),
				
				    // ---------- Build schedule keys for anti-join (what's already in schedule) ----------
				    Sched_ToKeys =
				        Table.Buffer(
				            Table.Distinct(
				                Table.SelectColumns(LeftKeysNormalized, {"site_id","to_movement_id"})
				            )
				        ),
				    Sched_FromKeys =
				        Table.Buffer(
				            Table.Distinct(
				                Table.SelectColumns(LeftKeysNormalized, {"site_id","from_movement_id"})
				            )
				        ),
				
				    // ---------- Shipments that ended but have NO schedule row ----------
				    ShipLogStarted =
				        Table.SelectRows(AS_Shipments_Log, each [started_utc] <> null),
				
				    ShipLogCompletedKeys =
				        Table.TransformColumns(
				            ShipLogCompleted,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"shipment_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				    Ship_NoSched_Anti =
				        Table.NestedJoin(
				            ShipLogStarted, {"site_id","shipment_id"},
				            Sched_ToKeys,         {"site_id","to_movement_id"},
				            "Sched", JoinKind.LeftAnti
				        ),
				    Ship_NoSched =
				        Table.RemoveColumns(Ship_NoSched_Anti, {"Sched"}),
				
				    // bring door assignment by movement_id (optional but useful)
				    Ship_NoSched_WithDoor =
				        Table.NestedJoin(
				            Ship_NoSched, {"site_id","shipment_id"},
				            AS_Result_Door_Assignment, {"site_id","movement_id"},
				            "Door", JoinKind.LeftOuter
				        ),
				    Ship_NoSched_ExpandDoor =
				        Table.ExpandTableColumn(Ship_NoSched_WithDoor, "Door", {"door_id"}, {"door_id_assigned_shipment_nosched"}),
				
				    // ---------- Receipts that ended but have NO schedule row ----------
				    RcptLogStarted =
				        Table.SelectRows(AS_Receipts_Log, each [started_utc] <> null),
				
				    RcptLogStartedKeys =
				        Table.TransformColumns(
				            RcptLogStarted,
				            {
				                {"site_id", each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"receipt_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				    Rcpt_NoSched_Anti =
				        Table.NestedJoin(
				            RcptLogStartedKeys, {"site_id","receipt_id"},
				            Sched_FromKeys,       {"site_id","from_movement_id"},
				            "Sched", JoinKind.LeftAnti
				        ),
				        
				    Rcpt_NoSched =
				        Table.RemoveColumns(Rcpt_NoSched_Anti, {"Sched"}),
				
				    Rcpt_NoSched_WithDoor =
				        Table.NestedJoin(
				            Rcpt_NoSched, {"site_id","receipt_id"},
				            AS_Result_Door_Assignment, {"site_id","movement_id"},
				            "Door", JoinKind.LeftOuter
				        ),
				    Rcpt_NoSched_ExpandDoor =
				        Table.ExpandTableColumn(Rcpt_NoSched_WithDoor, "Door", {"door_id"}, {"door_id_assigned_receipt_nosched"}),
				
				    // ---------- Shape the "no-schedule" rows to match your existing schema ----------
				    FinalCols = Table.ColumnNames(ExpandedAgg),
				
				    // Shipments: map to *_shipment fields; set schedule keys and aggregates
				    Ship_NoSched_Shaped =
				        let
				            base = Table.SelectColumns(
				                Ship_NoSched_ExpandDoor,
				                {
				                    "site_id","shipment_id","appointment_date","appointment_date_utc","carrier_id",
				                    "ended","ended_utc","is_live","late_after","late_after_utc","planned_arrival",
				                    "planned_arrival_utc","started","started_utc","arrived","arrived_utc",
				                    "trailer_id","transportation_type_id","customers","note",
				                    "orders","ordered_items","ordered_buom","ordered_cases","ordered_ULs","ordered_kg",
				                    "ordered_weight","ordered_weight_uom","ordered_cm3","ordered_volume","ordered_volume_uom",
				                    "loaded_items","loaded_buom","loaded_cases","loaded_ULs","loaded_kg","loaded_weight",
				                    "loaded_weight_uom","loaded_cm3","loaded_volume","loaded_volume_uom","shipment_type_id",
				                    "door_id_assigned_shipment_nosched"
				                },
				                MissingField.Ignore
				            ),
				            addSchedKeys1 = Table.AddColumn(base, "from_movement_id", each null, type text),
				            addSchedKeys2 = Table.AddColumn(addSchedKeys1, "from_movement_type", each "#unknown", type text),
				            addSchedKeys3 = Table.AddColumn(addSchedKeys2, "to_movement_id", each [shipment_id], type text),
				            addSchedKeys4 = Table.AddColumn(addSchedKeys3, "to_movement_type", each "shipment", type text),
				            renamed =
				                Table.RenameColumns(
				                    addSchedKeys4,
				                    {
				                        {"appointment_date","appointment_date_shipment"},
				                        {"appointment_date_utc","appointment_date_utc_shipment"},
				                        {"carrier_id","carrier_id_shipment"},
				                        {"ended","ended_shipment"},
				                        {"ended_utc","ended_utc_shipment"},
				                        {"is_live","is_live_shipment"},
				                        {"late_after","late_after_shipment"},
				                        {"late_after_utc","late_after_utc_shipment"},
				                        {"planned_arrival","planned_arrival_shipment"},
				                        {"planned_arrival_utc","planned_arrival_utc_shipment"},
				                        {"started","started_shipment"},
				                        {"started_utc","started_utc_shipment"},
				                        {"arrived","arrived_shipment"},
				                        {"arrived_utc","arrived_utc_shipment"},
				                        {"trailer_id","trailer_id_shipment"},
				                        {"transportation_type_id","transportation_type_shipment"},
				                        {"note","note_shipment"},
				                        {"door_id_assigned_shipment_nosched","door_id_assigned_shipment"}
				                    },
				                    MissingField.Ignore
				                ),
				            // aggregates not present in schedule-only rows: leave nulls
				            addAggNulls1 = Table.AddColumn(renamed, "MinStart_UTC", each null, type datetime),
				            addAggNulls2 = Table.AddColumn(addAggNulls1, "MaxEnd_UTC", each null, type datetime),
				            addAggNulls3 = Table.AddColumn(addAggNulls2, "MinStart", each null, type datetime),
				            addAggNulls4 = Table.AddColumn(addAggNulls3, "MaxEnd", each null, type datetime),
				
				            // ensure all final columns exist (add missing with null)
				            addMissingCols =
				                List.Accumulate(
				                    List.Difference(FinalCols, Table.ColumnNames(addAggNulls4)),
				                    addAggNulls4,
				                    (state as table, col as text) => Table.AddColumn(state, col, each null, type any)
				                ),
				            aligned = Table.SelectColumns(addMissingCols, FinalCols, MissingField.UseNull)
				        in
				            aligned,
				
				    // Receipts: map to *_receipt fields; set schedule keys and aggregates
				    Rcpt_NoSched_Shaped =
				        let
				            base = Table.SelectColumns(
				                Rcpt_NoSched_ExpandDoor,
				                {
				                    "site_id","receipt_id","appointment_date","appointment_date_utc","carrier_id",
				                    "ended","ended_utc","is_live","late_after","late_after_utc","planned_arrival",
				                    "planned_arrival_utc","started","started_utc","arrived","arrived_utc",
				                    "trailer_id","transportation_type_id","origin","note",
				                    "expected_items","expected_buom","expected_cases","expected_ULs","expected_kg",
				                    "expected_weight","expected_weight_uom","expected_cm3","expected_volume","expected_volume_uom",
				                    "received_items","received_buom","received_cases","received_ULs","received_kg","received_weight",
				                    "received_weight_uom","received_cm3","received_volume","received_volume_uom","receipt_type_id",
				                    "door_id_assigned_receipt_nosched"
				                },
				                MissingField.Ignore
				            ),
				            addSchedKeys1 = Table.AddColumn(base, "from_movement_id", each [receipt_id], type text),
				            addSchedKeys2 = Table.AddColumn(addSchedKeys1, "from_movement_type", each "receipt", type text),
				            addSchedKeys3 = Table.AddColumn(addSchedKeys2, "to_movement_id", each null, type text),
				            addSchedKeys4 = Table.AddColumn(addSchedKeys3, "to_movement_type", each "#unknown", type text),
				            renamed =
				                Table.RenameColumns(
				                    addSchedKeys4,
				                    {
				                        {"appointment_date","appointment_date_receipt"},
				                        {"appointment_date_utc","appointment_date_utc_receipt"},
				                        {"carrier_id","carrier_id_receipt"},
				                        {"ended","ended_receipt"},
				                        {"ended_utc","ended_utc_receipt"},
				                        {"is_live","is_live_receipt"},
				                        {"late_after","late_after_receipt"},
				                        {"late_after_utc","late_after_utc_receipt"},
				                        {"planned_arrival","planned_arrival_receipt"},
				                        {"planned_arrival_utc","planned_arrival_utc_receipt"},
				                        {"started","started_receipt"},
				                        {"started_utc","started_utc_receipt"},
				                        {"arrived","arrived_receipt"},
				                        {"arrived_utc","arrived_utc_receipt"},
				                        {"trailer_id","trailer_id_receipt"},
				                        {"transportation_type_id","transportation_type_receipt"},
				                        {"note","note_receipt"},
				                        {"door_id_assigned_receipt_nosched","door_id_assigned_receipt"}
				                    },
				                    MissingField.Ignore
				                ),
				                    // aggregates not present in schedule-only rows: leave nulls
				            addAggNulls1 = Table.AddColumn(renamed, "MinStart_UTC", each null, type datetime),
				            addAggNulls2 = Table.AddColumn(addAggNulls1, "MaxEnd_UTC", each null, type datetime),
				            addAggNulls3 = Table.AddColumn(addAggNulls2, "MinStart", each null, type datetime),
				            addAggNulls4 = Table.AddColumn(addAggNulls3, "MaxEnd", each null, type datetime),
				
				            // ensure all final columns exist (add missing with null)
				            addMissingCols =
				                List.Accumulate(
				                    List.Difference(FinalCols, Table.ColumnNames(addAggNulls4)),
				                    addAggNulls4,
				                    (state as table, col as text) => Table.AddColumn(state, col, each null, type any)
				                ),
				            aligned = Table.SelectColumns(addMissingCols, FinalCols, MissingField.UseNull)
				        in
				            aligned,
				
				    // ---------- Append to your existing table ----------
				    Combined_All = Table.Combine({ ExpandedAgg, Ship_NoSched_Shaped, Rcpt_NoSched_Shaped }),
				    Combined_All_WithTrailer =
				        Table.NestedJoin(
				            Combined_All, {"site_id","shipment_id"},
				            AS_Shipments_with_Overrides, {"site_id","shipment_id"},
				            "ShipOverrides", JoinKind.LeftOuter
				        ),
				    Expanded_All_WithTrailer =
				        Table.ExpandTableColumn(
				            Combined_All_WithTrailer, "ShipOverrides",
				            {"trailer_type"},
				            {"TrailerType_Shipment"}
				        ),
				    // -------------------------------------------------------------------
				    // Back-fill door_id_assigned_* for ALL rows (incl. completed/no-schedule)
				    // -------------------------------------------------------------------
				
				    // Build a "latest per site_id + movement_id" from AS_Result_Door_Assignment
				    DoorAssignKeys =
				        Table.TransformColumns(
				            AS_Result_Door_Assignment,
				            {
				                {"site_id",     each Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"movement_id", each Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				    DoorAssignSorted = Table.Sort(DoorAssignKeys, {{"updated_utc", Order.Descending}}),
				    DoorLatest =
				        Table.SelectColumns(
				            Table.Distinct(DoorAssignSorted, {"site_id","movement_id"}),
				            {"site_id","movement_id","door_id"}
				        ),
				
				    // Normalize keys on the combined fact for the join
				    FactForDoorBF =
				        Table.TransformColumns(
				            Expanded_All_WithTrailer,              // <— use your table after trailer merge
				            {
				                {"site_id",          each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"to_movement_id",   each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text},
				                {"from_movement_id", each if _ = null then null else Text.Upper(Text.Trim(Text.From(_))), type text}
				            }
				        ),
				
				    // Join latest door on shipment side (to_movement_id)
				    MergeDoorShipBF =
				        Table.NestedJoin(
				            FactForDoorBF, {"site_id","to_movement_id"},
				            DoorLatest,    {"site_id","movement_id"},
				            "DoorBF_Ship", JoinKind.LeftOuter
				        ),
				    ExpandDoorShipBF =
				        Table.ExpandTableColumn(MergeDoorShipBF, "DoorBF_Ship", {"door_id"}, {"door_assigned_ship_fill"}),
				
				    // Join latest door on receipt side (from_movement_id)
				    MergeDoorRcptBF =
				        Table.NestedJoin(
				            ExpandDoorShipBF, {"site_id","from_movement_id"},
				            DoorLatest,       {"site_id","movement_id"},
				            "DoorBF_Rcpt", JoinKind.LeftOuter
				        ),
				    ExpandDoorRcptBF =
				        Table.ExpandTableColumn(MergeDoorRcptBF, "DoorBF_Rcpt", {"door_id"}, {"door_assigned_rcpt_fill"}),
				
				    // Backfill: keep existing assigned door if present, else take the latest fill
				    AssignedDoorBackfilled =
				        Table.AddColumn(
				            Table.AddColumn(
				                ExpandDoorRcptBF,
				                "door_id_assigned_shipment_final",
				                each let cur = [door_id_assigned_shipment], fill = [door_assigned_ship_fill]
				                    in if cur <> null and Text.Trim(Text.From(cur)) <> "" then cur else fill,
				                type text
				            ),
				            "door_id_assigned_receipt_final",
				            each let cur = [door_id_assigned_receipt], fill = [door_assigned_rcpt_fill]
				                in if cur <> null and Text.Trim(Text.From(cur)) <> "" then cur else fill,
				            type text
				        ),
				
				    DoorBF_Cleanup =
				        Table.RemoveColumns(
				            AssignedDoorBackfilled,
				            {"door_assigned_ship_fill","door_assigned_rcpt_fill","door_id_assigned_shipment","door_id_assigned_receipt"}
				        ),
				    WithAssignedDoorFinal =
				        Table.RenameColumns(
				            DoorBF_Cleanup,
				            {
				                {"door_id_assigned_shipment_final","door_id_assigned_shipment"},
				                {"door_id_assigned_receipt_final","door_id_assigned_receipt"}
				            }
				        ),
				    
				    // ---- FINAL, FORCE DATA TYPES AFTER APPEND ----
				    
				    // Map of desired column types
				    TypeMap = {
				        // schedule activity core
				        {"site_id",               type text},
				        {"action_id",             type text},
				        {"actor_id",              type text},
				        {"equipment_id",          type text},
				        {"from_movement_id",      type text},
				        {"from_movement_type",    type text},
				        {"to_movement_id",        type text},
				        {"to_movement_type",      type text},
				        {"quantity_ul",           type number},
				        {"work_hours_standard",   type number},
				        {"start_utc",             type datetime},
				        {"end_utc",               type datetime},
				        {"start",                 type datetime},
				        {"end",                   type datetime},
				        {"updated_utc",           type datetime},
				        {"updated",               type datetime},
				
				        // aggregates
				        {"MinStart_UTC",          type datetime},
				        {"MaxEnd_UTC",            type datetime},
				        {"MinStart",              type datetime},
				        {"MaxEnd",                type datetime},
				
				        // shipments (assigned/proposed may be text)
				        {"shipment_id",                   type text},
				        {"is_live_shipment",              type text},     // or type logical if true/false only
				        {"appointment_date_shipment",     type datetime},
				        {"appointment_date_utc_shipment", type datetime},
				        {"planned_arrival_shipment",      type datetime},
				        {"planned_arrival_utc_shipment",  type datetime},
				        {"arrived_shipment",              type datetime},
				        {"arrived_utc_shipment",          type datetime},
				        {"started_shipment",              type datetime},
				        {"started_utc_shipment",          type datetime},
				        {"ended_shipment",                type datetime},
				        {"ended_utc_shipment",            type datetime},
				        {"late_after_shipment",           type datetime},
				        {"late_after_utc_shipment",       type datetime},
				        {"carrier_id_shipment",           type text},
				        {"trailer_id_shipment",           type text},
				        {"TrailerType_Shipment",           type text},
				        {"transportation_type_shipment",  type text},
				        {"ordered_cases",                 type number},
				        {"loaded_cases",                  type number},
				        {"door_id_assigned_shipment",     type text},
				        {"Door_Proposed_shipment",              type text},   
				
				        // receipts
				        {"receipt_id",                    type text},
				        {"is_live_receipt",               type text},     // or type logical
				        {"appointment_date_receipt",      type datetime},
				        {"appointment_date_utc_receipt",  type datetime},
				        {"planned_arrival_receipt",       type datetime},
				        {"planned_arrival_utc_receipt",   type datetime},
				        {"arrived_receipt",               type datetime},
				        {"arrived_utc_receipt",           type datetime},
				        {"started_receipt",               type datetime},
				        {"started_utc_receipt",           type datetime},
				        {"ended_receipt",                 type datetime},
				        {"ended_utc_receipt",             type datetime},
				        {"late_after_receipt",            type datetime},
				        {"late_after_utc_receipt",        type datetime},
				        {"carrier_id_receipt",            type text},
				        {"trailer_id_receipt",            type text},
				        {"transportation_type_receipt",   type text},
				        {"expected_cases",                type number},
				        {"received_cases",                type number},
				        {"door_id_assigned_receipt",      type text},
				        {"Door_Proposed_Receipt",              type text}
				    },
				
				    ExistingCols    = Table.ColumnNames(WithAssignedDoorFinal),
				    ExistingTypeMap = List.Select(TypeMap, each List.Contains(ExistingCols, _{0})),
				    TypedFinal      = Table.TransformColumnTypes(WithAssignedDoorFinal, ExistingTypeMap, "en-US"),
				    #"Filtered Rows" = Table.SelectRows(TypedFinal, each [shipment_type_id] <> "freightUnit")
				in
				    #"Filtered Rows"
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

