	partition AS_Shipments_Log = m
		mode: import
		source =
				let
				    convert_to_table = call_api(
				        "/external-view/shipment-log",
				        type table [
				            site_id = text,
				            shipment_id = text,
				            shipment_type_id = text,
				            customers = text,
				            note = text,
				            is_live = logical,
				            planned_arrival_utc = datetime,
				            planned_arrival = datetime,
				            arrived_utc = datetime,
				            arrived = datetime,
				            appointment_date_utc = datetime,
				            appointment_date = datetime,
				            transportation_type_id = text,
				            started_utc = datetime,
				            started = datetime,
				            ended_utc = datetime,
				            ended = datetime,
				            carrier_id = text,
				            trailer_id = text,
				            door_id = text,
				            door_assigned_utc = datetime,
				            door_assigned = datetime,
				            last_updated_utc = datetime,
				            last_updated = datetime,
				            first_updated_utc = datetime,
				            first_updated = datetime,
				            orders = Int64.Type,
				            ordered_items = Int64.Type,
				            ordered_buom = number,
				            ordered_cases = number,
				            ordered_ULs = number,
				            ordered_kg = number,
				            ordered_weight = number,
				            ordered_cm3 = number,
				            ordered_volume = number,
				            loaded_buom = number,
				            loaded_cases = number,
				            loaded_ULs = number,
				            loaded_kg = number,
				            loaded_items = number,
				            loaded_weight = number,
				            loaded_cm3 = number,
				            loaded_volume = number,
				            late_after_utc = datetime,
				            late_after = datetime,
				            last_scheduled_end_utc = datetime,
				            last_scheduled_end = datetime
				        ]
				    )
				in
				    convert_to_table

