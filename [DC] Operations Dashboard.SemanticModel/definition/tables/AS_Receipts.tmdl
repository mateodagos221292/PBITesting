	partition AS_Receipts = m
		mode: import
		source =
				let
				    convert_to_table = call_api(
				        "/external-view/receipt",
				        type table [
				            site_id = text,
				            receipt_id = text,
				            receipt_type_id = text,
				            is_live = logical,
				            appointment_date_UTC = datetime,
				            appointment_date = datetime,
				            transportation_type_id = text,
				            carrier_id = text,
				            trailer_id = text,
				            arrived_UTC = datetime,
				            arrived = datetime,
				            is_completed = logical,
				            assigned_door_id = text,
				            is_suspended = logical,
				            planned_arrival_utc = datetime,
				            planned_arrival = datetime,
				            origin_id = text,
				            note = text
				        ]
				    )
				in
				    convert_to_table

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

