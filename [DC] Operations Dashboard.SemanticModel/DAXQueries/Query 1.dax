Hours_to_Scheduled_End :=
VAR now = UTCNOW()
RETURN
IF(
    ISBLANK(AS_Result_schedule_activity[end_utc]),
    BLANK(),
    DATEDIFF(now, AS_Result_schedule_activity[end_utc], MINUTE) / 60.0
)

Hours_since_start_Shipment :=
VAR now = UTCNOW()
RETURN
IF(
    ISBLANK(AS_Result_schedule_activity[Shipment_started_utc]),
    BLANK(),
    DATEDIFF(AS_Result_schedule_activity[Shipment_started_utc], now, MINUTE) / 60.0
)

